        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var skuCode = document.getElementById("skuCode").value;

                // Call the API to get the product rating based on the SkuCode
                fetch(`/api/Rating?productid=${skuCode}`)
                    .then(response => response.json())
                    .then(data => {
                        var averageRating = data.rating;

                        averageRating = Math.min(Math.max(averageRating, 0), 5);

                        var ratingIcons = document.getElementsByClassName("ratting-icons")[0];
                        ratingIcons.innerHTML = '';

                        // Add filled stars based on the average rating
                        for (var i = 0; i < 5; i++) {
                            var star = document.createElement("i");
                            if (i < averageRating) {
                                star.className = "lastudioicon-star-rate-1";
                            }
                            else{
                                star.className = "lastudioicon-star-rate-2";
                            }
                            ratingIcons.appendChild(star);
                        }

                        // Update the review count (modify as needed)
                        document.querySelector(".review-count").textContent = data.custom ;
                    })
                    .catch(error => {
                        console.error("Error fetching rating:", error);
                    });


            });
        </script>
        <script>

            function HandleBuyNow() {
                console.log("hello");
                // Set the hidden input field 'buynow' to true
                document.getElementById('buynow1').value = 'true';

                // Programmatically submit the form
                document.querySelector('form').submit();

            }
            //for wishlist
            function HandleAddToWishlist2(skuCode, productName) {
                // Prevent the default action
                event.preventDefault();

                // Set the product-specific values in the hidden form fields
                document.getElementById('SkuCode').value = skuCode;
                document.getElementById('ProductName').value = productName;

                // Set buynow to false for normal wishlist action
                document.getElementById('buynow').value = 'true';

                // Submit the form programmatically
                document.getElementById('wishlistForm').submit();
            }


        </script>
