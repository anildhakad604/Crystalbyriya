                                                        </label>
                                                        <div id="review-images-parent"></div>
                                                    </div>
                                                </div>
                                                <!-- Review Text Input -->
                                                <div class="col-md-12">
                                                    <div class="form-group">
                                                        <label for="reviewFormTextarea" class="fw-medium mb-2">Your review</label>
                                                        <textarea class="form-control" id="reviewFormTextarea" name="ReviewText" rows="5" required></textarea>
                                                    </div>
                                                </div>

                                                <!-- Submit Button -->
                                                @if (string.IsNullOrEmpty(UserEmail))
                                                {
                                                    <!-- Display login message if the user is not logged in -->
                                                    <div class="row">
                                                        <div class="col-md-12">
                                                            <div class="alert alert-warning text-center">
                                                                <p>Please <a href="/myaccount">login</a> to submit a review.</p>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="col-md-12 mt-3">
                                                        <div class="form-group">
                                                            <button class="btn btn-theme btn-black" id="submitbtn" type="submit">Submit</button>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>

                </div>
                <div class="col-md-6">
                    <div class="product-review-comments-parent">
                        @if (Model.CombinedReviews != null)
                        {
                            @foreach (var review in Model.CombinedReviews.Where(r => r.IsApprovedReview == true))
                            {
                                <div class="product-review-comment">
                                    <div class="comment-item">
                                        <!-- Header: Reviewer Info -->
                                        <div class="comment-header-parent d-flex align-items-center mb-2">
                                            <div class="thumb me-3">
                                                <img src="https://ik.imagekit.io/rjqr7zeeq/Icons/Screenshot%202024-12-15%20195804.png?updatedAt=1734272946687" alt="@review.ReviewerName" />
                                            </div>
                                            <div class="comment-title">
                                                <h5 class="comment-by fw-semibold mb-2">@review.ReviewerName</h5>
                                                <p class="date">@review.ReviewDate?.ToString("dd MMM yyyy")</p>
                                            </div>
                                        </div>

                                        <!-- Content: Review Text and Rating -->
                                        <div class="content mb-2">
                                            <div class="rating">
                                                @for (int i = 0; i < review.Rating; i++) // Display filled stars based on rating
                                                {
                                                    <span class="lastudioicon-star-rate-1" style="color: gold;"></span>
                                                }

                                                @for (int i = 0; i < (5 - review.Rating); i++) // Display remaining empty stars
                                                {
                                                    <span class="lastudioicon-star-rate-2" style="color: lightgray;"></span>
                                                }
                                            </div>
                                            <span class="review">@review.ReviewText</span>
                                        </div>

                                        <!-- Images: Review Gallery -->
                                        @if (!string.IsNullOrEmpty(review.ImageName) && review.IsApprovedGallery == true)
                                        {
                                            <div class="review-img-parent">
                                                <a class="review-img" data-fancybox="gallery2" href="@Url.Content("https://www.crystalsbyriya.com/images/" + @review.ImageName)">
                                                    <img src="@Url.Content("https://www.crystalsbyriya.com/images/" + @review.ImageName)" alt="review-img" />
                                                </a>

                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <!-- Display if no reviews are available -->
                            <p>No customer reviews available for this product.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>
