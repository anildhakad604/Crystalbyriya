                                                        </svg>
                                                        <div class="text">Verified Purchase</div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="list-star d-flex justify-content-center gap-4">
                                                @for (int s = 1; s <= 5; s++)
                                                {
                                                    <svg width="14" height="14" viewbox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                        <path d="M14 5.4091L8.913 5.07466L6.99721 0.261719L5.08143 5.07466L0 5.4091L3.89741 8.7184L2.61849 13.7384L6.99721 10.9707L11.376 13.7384L10.097 8.7184L14 5.4091Z" fill="@(s <= review.Rating ? "#EF9122" : "#DDDDDD")"></path>
                                                    </svg>
                                                }
                                            </div>
                                        </div>
                                        <p class="h6 desc">@review.ReviewText</p>
                                        <div class="text-small time text-main-2">@review.ReviewDate?.ToString("MMMM d, yyyy")</div>
                                    </div>
                                </div>
                                    }
                                }
                                else
                                {
                                    <p class="h6 text-main-2">No reviews yet. Be the first to review this product!</p>
                                }
                            </div>
                        </div>
                        <form class="form-write-review write-review-wrap" method="post" asp-page-handler="Review">
                            <div class="heading h2 fw-4 text-black">Write a review:</div>
                            <div class="text h6 fw-4">
                                All of your information will be kept confidential. Required fields are marked with an
                                asterisk (*)
                            </div>
                             <div class="your-rating">
                                <div class="h4 fw-4 text-black">Your rating:</div>
                                <div class="list-rating-check">
                                    @for (int rating = 5; rating >= 1; rating--)
                                    {
                                        <input type="radio" id="star@(rating)" name="rate" value="@rating" 
                                               onclick="document.getElementById('RatingValue').value = @(rating)">
                                        <label for="star@(rating)" title="@rating star(s)"></label>
                                    }
                                </div>
                            </div>
                            <div class="form-content">
                                <div class="your-review">
                                    <div class="h4 fw-4 text-black">Your review:</div>
                                    <textarea name="ReviewText" rows="5" class="tf-input" required 
                                              placeholder="Share your experience with this product..."
                                              maxlength="1000"></textarea>
                                </div>
                                <input type="hidden" name="ProductId" value="@Model.Products?.SkuCode" />
                                <input type="hidden" id="RatingValue" name="Rating" value="5" />
                                <button type="submit" class="tf-btn animate-btn">
                                    Submit Review
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
                <div class="tab-pane wd-product-descriptions" id="faqs" role="tabpanel">
                    <div class="tab-faqs">
                        <div class="tab-pane tab-faqs-descriptions active show" id="faqs-list" role="tabpanel">
                            <ul>
                                
                                    @foreach (var faq in Model.ProductFaqs)
                                    {
                                        <li>
                                            <div class="h6 fw-6 text-black title">@faq.Question</div>
                                            <div class="h6 fw-4 text">@faq.Answer</div>
                                        </li>
                                    }
                                
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>
<!-- /Product Description -->
<!-- Box Icon -->
<section>
    <div class="container">
        <div class="sect-border">
            <div class="s-head">
                <h3 class=" s-title fw-normal"> @(Model.Products?.ProductName ?? "Recommended For You")</h3>
            </div>
            <div dir="ltr" class="swiper tf-swiper" data-preview="4" data-tablet="3" data-mobile-sm="2" data-mobile="1" data-space-lg="97" data-space-md="33" data-space="13" data-pagination="1" data-pagination-sm="2" data-pagination-md="3" data-pagination-lg="4">
                <div class="swiper-wrapper">
                    <!-- item 1 -->
                    @foreach (var item in Model.ProductFaqs)
                    {
                        <div class="swiper-slide">
                            <div class="box-icon_V01">
                                <span class="icon">
                                    <i class="icon-package"></i>
                                </span>
                                <div class="content">
                                    <h4 class="title fw-normal"> @item.Question</h4>
                                    <p class="text">@item.Answer</p>
                                </div>
                            </div>
                        </div>
                    }
                   
                  
                </div>
                <div class="sw-dot-default tf-sw-pagination"></div>
            </div>
        </div>
    </div>
</section>
<!-- /Box Icon -->
<!-- Also Like -->
<section class="flat-spacing-3">
    <div class="container">
        <h1 class="sect-title text-center">You May Also Like</h1>
        <div dir="ltr" class="swiper tf-swiper wrap-sw-over" data-preview="4" data-tablet="3" data-mobile-sm="2" data-mobile="2" data-space-lg="48" data-space-md="30" data-space="12" data-pagination="2" data-pagination-sm="2" data-pagination-md="3" data-pagination-lg="4">
            <div class="swiper-wrapper">
                <!-- Product 1 -->
                 @foreach (var item in Model.RecentlyViewedProducts)
                {
                    <div class="swiper-slide">
                        <div class="card-product">
                            <div class="card-product_wrapper">
                                <a asp-page="/detail" asp-route-skucode="@item.SkuCode" asp-route-productname="@item.ParentUrl" class="product-img">
                                    <img class="lazyload img-product" src="/images/products/@item.Thumbnail" data-src="/images/products/@item.Thumbnail" alt="@item.ProductName">
                                    <img class="lazyload img-hover" src="/images/products/@item.Thumbnail" data-src="/images/products/@item.Thumbnail" alt="@item.ProductName">
                                </a>
                                @if (Model.ProductSizes.Any(s => s.ProductID == item.SkuCode))
                                {
                                    <div class="variant-box">
                                        <ul class="product-size_list">
                                             @foreach (var size in Model.ProductSizes.Where(s => s.ProductID == item.SkuCode).Take(2))
                                                {
                                                     <li class="size-item h6">@size.Size</li>
                                                }
                                        </ul>
                                    </div>
                                }
                                
                            </div>
                            <div class="card-product_info">
                                <a asp-page="/detail" asp-route-skucode="@item.SkuCode" asp-route-productname="@item.ParentUrl"
                                   class="name-product h4 link">
                                    @item.ProductName
                                </a>

                                <div class="price-wrap">
                                    <span class="price-old h6 fw-normal">
                                        ₹@(item.Price + 200)
                                    </span>
                                    <span class="price-new h6">
                                        ₹@item.Price
                                    </span>
                                </div>
                                <ul class="product-color_list d-none">
                                    <li class="product-color-item color-swatch hover-tooltip tooltip-bot active">
                                        <span class="tooltip color-filter">Default</span>
                                        <span class="swatch-value bg-dark-charcoal"></span>
                                        <img class="lazyload" src="/images/products/@item.Thumbnail" data-src="/images/products/@item.Thumbnail" alt="@item.ProductName">
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="sw-dot-default tf-sw-pagination"></div>
        </div>
    </div>
</section>
<!-- /Also Like -->
<!-- Related -->
<section class="flat-spacing-3 pt-0">
    <div class="container">
        <h1 class="sect-title text-center">Related Products</h1>
        <div dir="ltr" class="swiper tf-swiper wrap-sw-over" data-preview="4" data-tablet="3" data-mobile-sm="2" data-mobile="2" data-space-lg="48" data-space-md="30" data-space="12" data-pagination="2" data-pagination-sm="2" data-pagination-md="3" data-pagination-lg="4">
            <div class="swiper-wrapper">
                <!-- Product 1 -->
                
              @if (Model.RelatedProducts != null && Model.RelatedProducts.Any())
                {
                    @foreach (var item in Model.RelatedProducts)
                    {
                        <div class="swiper-slide">
                            <div class="card-product">
                                <div class="card-product_wrapper">
                                    <a asp-page="/detail" asp-route-skucode="@item.SkuCode" asp-route-productname="@item.ParentUrl" class="product-img">
                                        <img class="lazyload img-product" src="/images/products/@item.Thumbnail" data-src="/images/products/@item.Thumbnail" alt="@item.ProductName">
                                        <img class="lazyload img-hover" src="/images/products/@item.Thumbnail" data-src="/images/products/@item.Thumbnail" alt="@item.ProductName">
                                    </a>
                                    
                                </div>
                                <div class="card-product_info">
                                    <a asp-page="/detail" asp-route-skucode="@item.SkuCode" asp-route-productname="@item.ParentUrl"
                                       class="name-product h4 link">
                                        @item.ProductName
                                    </a>
                                    <div class="price-wrap">
                                        <span class="price-old h6 fw-normal">
                                            ₹@(item.Price + 200)
                                        </span>
                                        <span class="price-new h6">
                                            ₹@item.Price
                                        </span>
                                    </div>
                                    <ul class="product-color_list">
                                        <li class="product-color-item color-swatch hover-tooltip tooltip-bot active">
                                            <span class="tooltip color-filter">Default</span>
                                            <span class="swatch-value bg-sage-green"></span>
                                            <img class="lazyload" src="/images/products/@item.Thumbnail" data-src="/images/products/@item.Thumbnail" alt="@item.ProductName">
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-center h6 text-main-2">No related products found.</p>
                }
            </div>
            <div class="sw-dot-default tf-sw-pagination"></div>
        </div>
    </div>
</section>
<!-- /Related -->

<script>
    function selectSize(size) {
        document.getElementById("selectedSize").value = size;

        document.querySelectorAll(".size-btn").forEach(btn => {
            btn.classList.remove("active");
            if (btn.innerText.trim() === size) {
                btn.classList.add("active");
            }
        });

        document.querySelector(".value-currentSize").innerText = size;
    }
</script>
