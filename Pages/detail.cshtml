                                <div class="product-info-price price-wrap">
                                    <span class="price-new price-on-sale h2 fw-4">
                                        ₹ @Model.Products?.Price
                                    </span>

                                    @* @if (Model.Products?.OldPrice != null)
                                    {
                                        <span class="price-old compare-at-price h6">
                                            ₹ @Model.Products.OldPrice
                                        </span>
                                    } *@
                                </div>
                            </div>

                            <!-- DESCRIPTION -->
                            <div class="tf-product-info-liveview">
                                <p class="fw-6 h6">
                                    @Model.Products?.ShortDescription
                                </p>
                            </div>

                            <!-- SIZE -->
                            <div class="tf-product-variant">
                                <div class="variant-picker-item variant-size">
                                    <div class="variant-picker-label">
                                        <div class="h4 fw-semibold">
                                            Size
                                            <span class="variant-picker-label-value value-currentSize">
                                                @(Model.SelectedSize ?? "Select Size")
                                            </span>
                                        </div>
                                    </div>

                                    <div class="variant-picker-values">
                                        @foreach (var size in Model.ProductSizes)
                                        {
                                            <span class="size-btn @(Model.SelectedSize == size.Size ? "active" : "")"
                                                  onclick="selectSize('@size.Size')">
                                                @size.Size
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>

                            <!-- FORM -->
                            <form method="post">

                                <input type="hidden" name="SkuCode" value="@Model.Products?.SkuCode" />
                                <input type="hidden" name="ProductName" value="@Model.Products?.ProductName" />
                                <input type="hidden" name="Price" value="@Model.Products?.Price" />
                                <input type="hidden" id="selectedSize" name="Size" value="@Model.SelectedSize" />

                                <div class="tf-product-total-quantity">
                                    <div class="group-btn">

                                        <!-- QTY -->
                                        <div class="wg-quantity">
                                            <button type="button" class="btn-quantity btn-decrease">
                                                <i class="icon icon-minus"></i>
                                            </button>
                                            <input class="quantity-product" type="text" name="Qty" value="1">
                                            <button type="button" class="btn-quantity btn-increase">
                                                <i class="icon icon-plus"></i>
                                            </button>
                                        </div>

                                        <!-- ADD TO CART -->
                                        <button type="submit"
                                                formaction="?handler=AddToCart"
                                                name="buynow" value="false"
                                                class="tf-btn animate-btn btn-add-to-cart">
                                            ADD TO CART
                                            <i class="icon icon-shopping-cart-simple"></i>
                                        </button>

                                        <!-- WISHLIST -->
                                        <button type="submit"
                                                formaction="?handler=AddToWishlist"
                                                name="buynow" value="false"
                                                class="hover-tooltip box-icon btn-add-wishlist">
                                            <span class="icon icon-heart"></span>
                                        </button>

                                    </div>

                                    <!-- BUY NOW -->
                                    <button type="submit"
                                            formaction="?handler=AddToCart"
                                            name="buynow" value="true"
                                            class="tf-btn btn-primary w-100">
                                        BUY IT NOW
                                    </button>

                                </div>

                            </form>

                            <!-- SKU -->
                            <ul class="tf-product-cate-sku">
                                <li class="item-cate-sku h6">
                                    <span class="label fw-6 text-black">SKU:</span>
                                    <span class="value text-main-2">
                                        @Model.Products?.SkuCode
                                    </span>
                                </li>

                                <li class="item-cate-sku h6">
                                    <span class="label fw-6 text-black">Category:</span>
                                    <span class="value text-main-2">
                                        @(string.IsNullOrWhiteSpace(Model.Products?.Tags) ? "Crystal Jewellery" : Model.Products.Tags)
                                    </span>
                                </li>
                            </ul>

                        </div>
                    </div>
                </div>
                <!-- /Product Info -->

            </div>
        </div>
    </div>
</section>
