                                    </svg>
                                </div>
                                <div class="tf-btn btn-white animate-btn animate-dark line btn-comment-review btn-write-review">
                                    Write a review
                                    <svg width="18" height="18" viewbox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M15.9834 5.15866L12.8412 2.0171C12.7367 1.9126 12.6127 1.82971 12.4762 1.77316C12.3397 1.71661 12.1933 1.6875 12.0456 1.6875C11.8978 1.6875 11.7515 1.71661 11.615 1.77316C11.4785 1.82971 11.3545 1.9126 11.25 2.0171L2.57977 10.6873C2.47485 10.7914 2.39167 10.9153 2.33506 11.0518C2.27844 11.1884 2.24953 11.3348 2.25001 11.4826V14.6248C2.25001 14.9232 2.36853 15.2093 2.57951 15.4203C2.79049 15.6313 3.07664 15.7498 3.37501 15.7498H15.1875C15.3367 15.7498 15.4798 15.6906 15.5853 15.5851C15.6907 15.4796 15.75 15.3365 15.75 15.1873C15.75 15.0381 15.6907 14.8951 15.5853 14.7896C15.4798 14.6841 15.3367 14.6248 15.1875 14.6248H8.10844L15.9834 6.74983C16.0879 6.64536 16.1708 6.52133 16.2274 6.38482C16.2839 6.24831 16.313 6.102 16.313 5.95424C16.313 5.80649 16.2839 5.66017 16.2274 5.52367C16.1708 5.38716 16.0879 5.26313 15.9834 5.15866ZM6.51727 14.6248H3.37501V11.4826L9.56251 5.29506L12.7048 8.43733L6.51727 14.6248ZM13.5 7.6421L10.3584 4.49983L12.0459 2.81233L15.1875 5.9546L13.5 7.6421Z" fill="black"></path>
                                    </svg>
                                </div>
                            </div>
                        </div>
                        <div class="reply-comment cancel-review-wrap">
                            <div class="reply-comment-filter d-flex mb_24 gap-20 align-items-center justify-content-between flex-wrap">
                                <div class="d-flex align-items-center flex-wrap gap-12">
                                    <div class="h6 fw-5">Filter by:</div>
                                    <div class="filter-start-wrap">
                                        <div class="filter-item h6 active">
                                            All
                                        </div>
                                        <div class="filter-item h6">
                                            5 star (<span class="number">@starCounts[5]</span>)
                                        </div>
                                        <div class="filter-item h6">
                                            4 star (<span class="number">@starCounts[4]</span>)
                                        </div>
                                        <div class="filter-item h6">
                                            3 star (<span class="number">@starCounts[3]</span>)
                                        </div>
                                        <div class="filter-item h6">
                                            2 star (<span class="number">@starCounts[2]</span>)
                                        </div>
                                        <div class="filter-item h6">
                                            1 star (<span class="number">@starCounts[1]</span>)
                                        </div>
                                    </div>
                                </div>
                                <div class="tf-dropdown-sort" data-bs-toggle="dropdown">
                                    <div class="btn-select">
                                        <span class="text-sort-value">Most Recent</span>
                                        <span class="icon icon-caret-down"></span>
                                    </div>
                                    <div class="dropdown-menu">
                                        <div class="select-item active">
                                            <span class="text-value-item">Most Recent</span>
                                        </div>
                                        <div class="select-item">
                                            <span class="text-value-item">Oldest</span>
                                        </div>
                                        <div class="select-item">
                                            <span class="text-value-item">Most Popular</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="reply-comment-wrap">
                                @if (Model.CombinedReviews != null && Model.CombinedReviews.Any(r => r.IsApprovedReview == true))
                                {
                                    @foreach (var review in Model.CombinedReviews.Where(r => r.IsApprovedReview == true))
                                    {
                                <div class="reply-comment-item">
                                    <div class="image">
                                   @if (!string.IsNullOrEmpty(review.ImageName))
                                        {
                                            <img class="lazyload" src="/images/gallery/@review.ImageName" alt="@review.ReviewerName">
                                        }
                                        else
                                        {
                                            <img class="lazyload" src="images/section/recent-1.jpg" alt="@review.ReviewerName">
                                        }
                                    </div>
                                    <div>
                                        <div class="user">
                                            <div class="flex-grow-1">
                                                <h4 class="name">
                                                    <a href="#" class="link">@review.ReviewerName</a>
                                                </h4>
                                                <div class="user-infor">
