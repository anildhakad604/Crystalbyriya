@functions {
    public string? CleanPrice(string? rawPrice)
    {
        if (string.IsNullOrWhiteSpace(rawPrice))
            return null;

        var cleaned = Regex.Replace(rawPrice, @"[^\d.]", "");

        if (decimal.TryParse(cleaned, NumberStyles.Any, CultureInfo.InvariantCulture, out var price))
            return price.ToString("0.##", CultureInfo.InvariantCulture);

        return null;
    }

    public string? AbsoluteUrl(string? url, HttpRequest request)
    {
        if (string.IsNullOrWhiteSpace(url))
            return null;

        if (Uri.TryCreate(url, UriKind.Absolute, out var absoluteUri))
            return absoluteUri.ToString();

        var baseUrl = $"{request.Scheme}://{request.Host}";

        if (!url.StartsWith("/"))
            url = "/" + url;

        return baseUrl + url;
    }

    public string? StripHtml(string? html)
    {
        if (string.IsNullOrWhiteSpace(html))
            return null;

        return Regex.Replace(html, "<.*?>", string.Empty).Trim();
    }

    public string? FirstNotEmpty(params string?[] values)
    {
        foreach (var value in values)
        {
            if (!string.IsNullOrWhiteSpace(value))
                return value.Trim();
        }

        return null;
    }

    public Dictionary<string, object?> BuildProductSchema(Product p, HttpRequest request)
    {
        var schema = new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "Product",
            ["name"] = p.ProductName,
            ["sku"] = p.SkuCode
        };

        var productUrl = AbsoluteUrl(p.ParentUrl, request);
        var imageUrl = AbsoluteUrl(p.Thumbnail, request);
        var description = FirstNotEmpty(
            StripHtml(p.ProductDescription),
            StripHtml(p.ShortDescription),
            p.MetaDescription,
            p.AltText
        );

        if (!string.IsNullOrWhiteSpace(productUrl))
            schema["url"] = productUrl;

        if (!string.IsNullOrWhiteSpace(imageUrl))
            schema["image"] = new[] { imageUrl };

        if (!string.IsNullOrWhiteSpace(description))
            schema["description"] = description;

        if (!string.IsNullOrWhiteSpace(p.Size))
            schema["size"] = p.Size;

        if (!string.IsNullOrWhiteSpace(p.Keywords))
            schema["keywords"] = p.Keywords;

        if (!string.IsNullOrWhiteSpace(p.Tags))
            schema["category"] = p.Tags;

        var price = CleanPrice(p.Price);

        var offer = new Dictionary<string, object?>
        {
            ["@type"] = "Offer",
            ["priceCurrency"] = "INR",
            ["availability"] = p.Qty > 0
                ? "https://schema.org/InStock"
                : "https://schema.org/OutOfStock",
            ["itemCondition"] = "https://schema.org/NewCondition"
        };

        if (!string.IsNullOrWhiteSpace(productUrl))
            offer["url"] = productUrl;

        if (!string.IsNullOrWhiteSpace(price))
            offer["price"] = price;

        schema["offers"] = offer;

        return schema;
    }
}
@{
    var product = Model.Products;
}

@if (product != null)
{
    var productSchema = BuildProductSchema(product, Request);

    <script type="application/ld+json">
        @Html.Raw(JsonSerializer.Serialize(productSchema))
    </script>
}
