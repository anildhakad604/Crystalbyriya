@page
@model CrystalByRiya.Pages.shop_accountModel
@{
}
@section Metatags {
    <title>My Account | Dr Astro Crystals</title>
    <meta name="description" content="Manage your Dr Astro Crystals account, view order history, and update your profile." />
    <meta name="keywords" content="My Account, Profile, Orders, Dr Astro Crystals" />
    <link rel="canonical" href="https://www.drastrocrystals.com/shop-account" />
    <meta property="og:title" content="My Account | Dr Astro Crystals" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://djelgxoby50a9.cloudfront.net/logo/logo.png" />
    <meta property="og:site_name" content="https://www.drastrocrystals.com" />
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="My Account | Dr Astro Crystals">
    <meta name="twitter:description" content="Manage your Dr Astro Crystals account, orders, and profile details.">
    <meta name="twitter:creator" content="Dr Astro Crystals">
    <meta name="twitter:image" content="https://djelgxoby50a9.cloudfront.net/logo/logo.png">
}

<!--== Start Page Title Area ==-->
<section class="s-page-title">
    <div class="container">
        <div class="content">
            <h1 class="title-page">My Account</h1>
            <ul class="breadcrumbs-page">
                <li><a asp-page="/Index" class="h6 link">Home</a></li>
                <li class="d-flex"><i class="icon icon-caret-right"></i></li>
                <li>
                    <h6 class="current-page fw-normal">My Account</h6>
                </li>
            </ul>
        </div>
    </div>
</section>
<!--== End Page Title Area ==-->

<!--== Start Account Area Wrapper ==-->
<section class="account-area flat-spacing">
    <div class="container">
        @if (string.IsNullOrEmpty(Model.UserEmail))
        {
            <div class="text-center py-5">
                <i class="icon icon-user fs-1 mb-3 text-secondary"></i>
                <h3>Please log in to view your account</h3>
                <a asp-page="/myaccount" class="tf-btn animate-btn mt-3">Login / Register</a>
            </div>
        }
        else
        {
            <div class="row">
                <div class="col-12">
                    <div class="section-title">
                        <h3 class="fw-semibold">Welcome, @Model.UserEmail</h3>
                    </div>
                </div>
            </div>
            <div class="row gy-3">
                <!-- Left sidebar nav -->
                <div class="col-md-4">
                    <div class="account-left-col">
                        <div class="profile-info-parent d-flex align-items-center mb-3">
                            <div class="profile-thumb me-2">
                                <img src="https://djelgxoby50a9.cloudfront.net/assetsv2/img/account/default-avatar.png" alt="Profile">
                            </div>
                            <div class="profile-name">
                                <h5 class="fw-semibold mb-0">@(Model.Detail?.Name ?? Model.UserEmail)</h5>
                            </div>
                        </div>
                        <div class="list-group" id="list-tab" role="tablist">
                            <a class="list-group-item list-group-item-action active" id="list-profile-list"
                               data-bs-toggle="list" href="#list-profile" role="tab" aria-controls="list-profile">
                                <i class="icon icon-user me-2"></i> Profile Details
                            </a>
                            <a class="list-group-item list-group-item-action" id="list-orders-list"
                               data-bs-toggle="list" href="#list-orders" role="tab" aria-controls="list-orders">
                                <i class="icon icon-shopping-cart-simple me-2"></i> Your Orders
                            </a>
                            <a class="list-group-item list-group-item-action" id="list-wishlist-list"
                               data-bs-toggle="list" href="#list-wishlist" role="tab" aria-controls="list-wishlist">
                                <i class="icon icon-heart me-2"></i> Your Wishlist
                            </a>
                            <a asp-page="/myaccount" class="list-group-item list-group-item-action text-danger">
                                <i class="icon icon-arrow-right me-2"></i> Go to Login / Register
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Right content panel -->
                <div class="col-md-8">
                    <div class="account-right-col">
                        <div class="tab-content" id="nav-tabContent">
                            <!-- Profile Tab -->
                            <div class="tab-pane fade show active" id="list-profile" role="tabpanel" aria-labelledby="list-profile-list">
                                <div class="account-details-parent">
                                    <div class="account-details-header d-flex justify-content-between pb-2 mb-2">
                                        <div class="section-title mb-0">
                                            <h5 class="fw-semibold mb-0 mt-2">Account Details</h5>
                                        </div>
                                    </div>
                                    <div class="row gy-2">
                                        <div class="col-md-12">
                                            <div class="form-group">
                                                <label class="form-label">Full Name</label>
                                                <input type="text" class="form-control" value="@Model.Detail?.Name" readonly>
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="form-group">
                                                <label class="form-label">Phone Number</label>
                                                <input type="text" class="form-control" value="@Model.Detail?.ContactNumber" readonly>
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="form-group">
                                                <label class="form-label">Email Address</label>
                                                <input type="email" class="form-control" value="@Model.Detail?.Emailid" readonly>
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="form-group">
                                                <label class="form-label">Street Address</label>
                                                <input type="text" class="form-control" value="@Model.Detail?.Address" readonly>
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="form-group">
                                                <label class="form-label">City</label>
                                                <input type="text" class="form-control" value="@Model.Detail?.City" readonly>
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="form-group">
                                                <label class="form-label">State</label>
                                                <input type="text" class="form-control" value="@Model.Detail?.State" readonly>
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="form-group">
                                                <label class="form-label">Pin Code</label>
                                                <input type="text" class="form-control" value="@Model.Detail?.PinCode" readonly>
                                            </div>
                                        </div>
                                        <div class="col-12 mt-3">
                                            <a asp-page="/dashboard" class="tf-btn animate-btn">
                                                Edit Profile &amp; View Full Dashboard
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Orders Tab (loaded via JS) -->
                            <div class="tab-pane fade" id="list-orders" role="tabpanel" aria-labelledby="list-orders-list">
                                <div class="text-center py-4">
                                    <p class="h6">Visit your <a asp-page="/dashboard" class="link fw-semibold">Dashboard</a> to view your full order history.</p>
                                </div>
                            </div>

                            <!-- Wishlist Tab -->
                            <div class="tab-pane fade" id="list-wishlist" role="tabpanel" aria-labelledby="list-wishlist-list">
                                <div class="text-center py-4">
                                    <p class="h6">Visit your <a asp-page="/wishlist" class="link fw-semibold">Wishlist</a> to view your saved products.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
<!--== End Account Area Wrapper ==-->