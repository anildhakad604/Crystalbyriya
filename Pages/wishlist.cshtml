

@page
@model CrystalByRiya.Pages.wishlistModel
@{
}
@section Metatags {
    <title>Your Wishlist | Dr Astro Crystals</title>
    <meta name="description" content="Manage your favorite healing crystals and spiritual products in your wishlist.">
    <link rel="canonical" href="@Model.Currenturl" />
}

<!-- Page Title -->
<section class="s-page-title">
    <div class="bg-overlay" style="background-image: url(images/banner/page-banner.jpg);">
        <div class="container">
            <div class="content">
                <h1 class="title-page">Your Wishlist</h1>
                <ul class="breadcrumbs-page">
                    <li><a asp-page="/Index" class="h6 link">Home</a></li>
                    <li class="d-flex"><i class="icon icon-caret-right"></i></li>
                    <li>
                        <h6 class="current-page fw-normal">Wishlist</h6>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</section>
<!-- /Page Title -->

<!-- Wishlist -->
<div class="flat-spacing">
    <div class="container">
        @if (Model.WishlistItems != null && Model.WishlistItems.Any())
        {
            <div class="tf-grid-layout tf-col-2 md-col-3 xl-col-4 wrapper-wishlist">
                @foreach (var item in Model.WishlistItems)
                {
                    <div class="card-product grid style-2 has-size">
                        <div class="card-product_wrapper">
                            <a asp-page="/detail" asp-route-skucode="@item.ProductId" asp-route-productname="@item.ProductName" class="product-img">
                                <img class="lazyload img-product" src="~/images/products/@item.Image" data-src="/images/products/@item.Image" alt="@item.ProductName">
                                <img class="lazyload img-hover" src="~/images/products/@item.Image" data-src="/images/products/@item.Image" alt="@item.ProductName">
                            </a>
                            <a asp-page="/wishlist" asp-page-handler="DeleteFromWishlist" asp-route-id="@item.ProductId" class="remove box-icon">
                                <i class="icon icon-trash"></i>
                            </a>
                            <ul class="product-action_list">
                                <li>
                                    <a asp-page="/detail" asp-route-skucode="@item.ProductId" asp-route-productname="@item.ProductName" class="hover-tooltip box-icon">
                                        <span class="icon icon-shopping-cart-simple"></span>
                                        <span class="tooltip">Add to cart</span>
                                    </a>
                                </li>
                                <li>
                                    <a asp-page="/detail" asp-route-skucode="@item.ProductId" asp-route-productname="@item.ProductName" class="hover-tooltip box-icon">
                                        <span class="icon icon-view"></span>
                                        <span class="tooltip">Quick view</span>
                                    </a>
                                </li>
                            </ul>
                        </div>
                        <div class="card-product_info">
                            <a asp-page="/detail" asp-route-skucode="@item.ProductId" asp-route-productname="@item.ProductName" class="name-product h4 link">@item.ProductName</a>
                            <div class="price-wrap">
                                <span class="price-new h6">₹@item.Price</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="icon icon-heart fs-1 mb-3 text-secondary"></i>
                <h3>Your wishlist is empty</h3>
                <p class="mb-4">Explore our collection and add your favorite crystals here!</p>
                <a asp-page="/Index" class="tf-btn animate-btn">Start Shopping</a>
            </div>
        }
    </div>
</div>
<!-- /Wishlist -->
