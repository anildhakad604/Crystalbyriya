                            data-pagination-lg="4" data-grid="2">
                            <div class="swiper-wrapper">
                                @foreach (var item in Model.Products.Take(10))
                                {
                                    <div class="swiper-slide">
                                        <div class="card-product">
                                            <div class="card-product_wrapper">
                                                <a asp-page="/detail" asp-route-skucode="@item.SkuCode" asp-route-productname="@item.ParentUrl" class="product-img">
