                                                <a asp-page="/detail" asp-route-skucode="@item.Skucode" asp-route-productname="@item.ParentUrl" class="name-product h4 link">
                                                    @item.ProductName
                                                </a>
                                                <div class="price-wrap">
                                                    <span class="price-new h6">₹@item.Price</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                            <div class="sw-dot-default tf-sw-pagination"></div>
                        </div>
                    </div>
                    <div class="tab-pane" id="on-sale" role="tabpanel">
                        <div dir="ltr" class="swiper tf-swiper wrap-sw-over" data-preview="4" data-tablet="3"
                            data-mobile-sm="2" data-mobile="2" data-space-lg="48" data-space-md="30" data-space="12"
                            data-pagination="2" data-pagination-sm="2" data-pagination-md="3" data-pagination-lg="4"
                            data-grid="2">
                            <div class="swiper-wrapper">
                                @foreach (var item in Model.Products.Take(10))
                                {
                                    <div class="swiper-slide">
                                        <div class="card-product">
                                            <div class="card-product_wrapper">
                                                <a asp-page="/detail" asp-route-skucode="@item.SkuCode" asp-route-productname="@item.ParentUrl" class="product-img">
                                                    <img class="lazyload img-product" src="/images/products/@item.Thumbnail"
                                                        data-src="/images/products/@item.Thumbnail" alt="@item.ProductName">
                                                    <img class="lazyload img-hover" src="/images/products/@item.Thumbnail"
                                                        data-src="/images/products/@item.Thumbnail" alt="@item.ProductName">
                                                </a>
                                                
                                            </div>
                                            <div class="card-product_info">
                                                <a asp-page="/detail" asp-route-skucode="@item.SkuCode" asp-route-productname="@item.ParentUrl" class="name-product h4 link">
