    <section class="Blogs-area area-padding">
        <div class="container">
            <div class="row">
                <div class="col-md-8 col-lg-6 m-auto">
                    <div class="section-title text-center aos-init aos-animate" data-aos="fade-up" data-aos-duration="1000">
                        <h2 class="title">Blogs</h2>
                    </div>
                </div>
            </div>
            <div class="row gy-3 aos-init aos-animate" data-aos="fade-up" data-aos-duration="1000">
                @if(Model.Blogs!=null && Model.Blogs.Any()){
                @foreach (var item in Model.Blogs)
                {
                    <div class="col-md-4">
                        <div class="blog-item-parent">
                            <div class="blog-item-thumb position-relative mb-1">
                                <div class="img-parent" data-date="@item.PublishedDate.ToString("dd MMM yyyy")">
                                    <img src="@item.ThumbnailImage" alt="">
                                </div>
                                <div class="blog-action" data-bs-toggle="modal" data-bs-target="#blogModal">
                                        <a class="action-quick-view ht-tooltip blogquickview" data-tippy-content="Quick View" id="@item.Blogid" href="javascript:void(0);">
                                        <i class="lastudioicon-eye"></i>
                                    </a>
                                </div>
                            </div>
                            <div class="blog-item-content">
                                <div class="meta">
                                    <a href="#">@item.Category</a>
                                    
                                </div>
                                <div class="inner-content">
                                    <h5 class="title">
                                        <a asp-route-blogid="@item.Blogid" asp-route-url="@item.CustomUrl" asp-page="blogdetail">@item.BlogTitle</a>
                                    </h5>
                                    <p>@item.ShortDescription</p>
                                </div>
                                <a asp-route-blogid="@item.Blogid" asp-route-url="@item.CustomUrl" asp-page="blogdetail" class="btn btn-read-more mt-2">Read more</a>
                            </div>
                        </div>
                    </div>
                    }
                }
                else
                {
                    <p> Nothing Here</p>
                }

                <div class="col-12">
                    <div class="btn-parent text-center mt-3 mt-md-5">
                        <a asp-page="/blog" class="btn btn-theme">VIEW ALL</a>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!--== End Blogs Area Wrapper ==-->
    <!--== Start Follow Us On Area Wrapper ==-->
    <section class="follow-us-on-area area-padding">
        <div class="container">
            <div class="row">
                <div class="col-md-8 col-lg-6 m-auto">
                    <div class="section-title text-center aos-init aos-animate" data-aos="fade-up" data-aos-duration="1000">
                        <h2 class="title">Follow Us On</h2>
                    </div>
                </div>
            </div>
            <div class="row aos-init aos-animate" data-aos="fade-up" data-aos-duration="1000">
                @if (Model.Instagrams != null && Model.Instagrams.Any())
                {
                    int count = 0;
                    foreach (var item in Model.Instagrams)
                    {
                        if (count >= 3)
                        {
                            break;
                        }
                        <div class="col-md-4">
                            <a href="https://instagram.com/crystalsbyriya" target="_blank" class="follow-video-parent">
                                <div class="video-parent">
                                    @Html.Raw(item.InstagramUrl)
                                </div>
                            </a>
                        </div>
                        count++;
                    }
                }
                else
                {
                    <p>Nothing Here</p>
                }
            </div>

        </div>
    </section>
