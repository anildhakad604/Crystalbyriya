@page
@model IndexModel
 @using Microsoft.AspNetCore.Http
  @inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Dr Astro Crystals - Home";
}

@{
    string userEmail = HttpContextAccessor.HttpContext.Session.GetString("UserEmail");
}
 
<!-- Banner Slider -->
<section class="tf-slideshow tf-btn-swiper-main">
            <div dir="ltr" class="swiper tf-swiper sw-slide-show slider_effect_fade" data-auto="true" data-loop="true"
                data-effect="fade" data-delay="3000">
                <div class="swiper-wrapper">
                    @foreach (var item in Model.Banners)
                    {
                        <div class="swiper-slide">
                            <div class="slider-wrap style-4">
                                <div class="sld_image">
                                    <img src="images/slider/@item.DesktopImageName" data-src="images/slider/@item.DesktopImageName" alt="@item.AltText" class="lazyload">
                                </div>
                                <div class="sld_content">
                                    <div class="container">
                                        <div class="content-sld_wrap">
                                            <h1 class="title_sld text-display fade-item fade-item-1 text-white">
                                                @item.Text
                                            </h1>
                                            <p class="sub-text_sld h5 fade-item fade-item-2 text-white">
                                                More than jewelry — a source of strength, clarity, and <br class="d-none d-sm-block"> emotional harmony you can wear daily.
                                            </p>
                                            <div class="fade-item fade-item-3">
                                                <a href="@item.TargetUrl" class="tf-btn animate-btn fw-semibold">
                                                    Shop now
                                                    <i class="icon icon-arrow-right"></i>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <div class="sw-dot-default tf-sw-pagination"></div>
            </div>
        </section>
<!-- /Banner Slider -->

 <!-- Collection -->
        <section class="s-collection">
            <div dir="ltr" class="swiper tf-swiper" data-preview="3" data-tablet="2" data-mobile-sm="2" data-mobile="1"
                data-pagination="1" data-space-lg="24" data-space-md="15" data-space="10" data-pagination-sm="1"
                data-pagination-md="2" data-pagination-lg="3">
                <div class="swiper-wrapper">
                 @if (Model.AllCategories != null && Model.AllCategories.Any())
                {
                foreach (var item in Model.AllCategories.Take(5))
                {
                    <div class="swiper-slide">
                        <div class="wg-cls-2 d-flex hover-img">
                            <a asp-page="/productlist" asp-route-catname="@item.MenuList" class="image img-style">
                                <img class="lazyload" src="~/images/category/@item.Image" data-src="/images/category/@item.Image"
                                alt="@(item.MenuList)">
                            </a>

                            <div class="cls-content_wrap b-16">
                                <div class="cls-content">
                                    <a asp-page="/productlist" asp-route-catname="@item.MenuList" class="tag_cls h3 link">@(item.MenuList)</a>
                                    <span class="br-line type-vertical"></span>
                                    <a asp-page="/productlist" asp-route-catname="@item.MenuList" class="tf-btn-line text-nowrap"> Shop now </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }

            }

           

        </div>
                <div class="sw-dot-default tf-sw-pagination"></div>
            </div>
        </section>
<!-- /Collection -->



 <!-- New -->
