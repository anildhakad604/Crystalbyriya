    <main class="main-content">
       
    <!--== Start Hero Area Wrapper ==-->
    <section class="home-slider-area slider-default">
        <!-- Add Logout Button Here -->
     
        <div class="home-slider-content">
            <div class="swiper-container home-slider-container">
                <div class="swiper-wrapper">
                    @if (Model.Banners != null && Model.Banners.Any())
{
                    @foreach (var item in Model.Banners)
                    {
                        if (item.Type == "Video")
                        {
                            <div class="swiper-slide">
                                <!-- Start Slide Item -->
                                <div class="home-slider-item">
                                    <div class="video-thumb">
                                        <video src="@item.DesktopImageName" autoplay muted loop class="position-absolute d-none d-md-block"></video>
                                        <video src="@item.MobileImageName" autoplay muted loop class="position-absolute d-md-none"></video>
                                    </div>
                                    <div class="slider-content-area position-relative">
                                        <div class="container">
                                            <div class="row align-items-center">
                                                <div class="col-md-12 col-lg-10 m-auto">
                                                    <div class="content">
                                                        <div class="inner-content">
                                                           @*  <h2>NEW IN</h2> *@
                                                            <p>@item.Text</p>
                                                            <a href="@item.TargetUrl" class="btn-theme btn-black mt-3">Shop Now</a>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!-- End Slide Item -->
                            </div>
                        }
                        else
                        {
                            <div class="swiper-slide">
                                <!-- Start Slide Item -->
                                <div class="home-slider-item">
                                    <div class="bg-thumb bg-overlay bg-img d-none d-md-block" data-bg-img="@item.DesktopImageName"></div>
                                    <div class="bg-thumb bg-overlay bg-img d-md-none" data-bg-img="@item.MobileImageName"></div>
                                    <div class="slider-content-area">
                                        <div class="container">
                                            <div class="row align-items-center">
                                                <div class="col-md-12 col-lg-10 m-auto">
                                                    <div class="content">
                                                        <div class="inner-content">
                                                          @*   <h2>NEW IN</h2> *@
                                                            <p>@item.Text</p>
                                                            <a href="@item.TargetUrl" class="btn-theme btn-black mt-3">Shop Now</a>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <!-- End Slide Item -->
                            </div>
                        }
                    }}
                    else
                    {
                        <p>No banners available.</p>
                    }
                </div>
                <!-- Add Arrows -->
                <div class="swiper-button-next"></div>
                <div class="swiper-button-prev"></div>
                <!-- Add Pagination -->
                <div class="swiper-pagination"></div>
            </div>
        </div>
    </section>
