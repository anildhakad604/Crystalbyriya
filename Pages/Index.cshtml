<!-- Shop By Intention -->
        <section class="flat-spacing bg-white-smoke">
            <div class=" container">
                <div class="sect-title text-center wow fadeInUp">
                    <h2 class="h1 sect-title text-black fw-medium text-center wow fadeInUp">Shop By Intention</h2>
                </div>
                <div dir="ltr" class="swiper tf-swiper wow fadeInUp" data-preview="6" data-tablet="4" data-mobile-sm="3"
                    data-mobile="2" data-space-lg="48" data-space-md="32" data-space="12" data-pagination="2"
                    data-pagination-sm="3" data-pagination-md="4" data-pagination-lg="6">
                    <div class="swiper-wrapper">
                        @if (Model.IntentionsItem != null && Model.IntentionsItem.Any())
                        {
                            @foreach (var item in Model.IntentionsItem)
                            {
                                <div class="swiper-slide">
                                    <a asp-page="/productlist" asp-route-catname="@item.IntentionImageUrl.Replace(' ', '-')" class="widget-collection style-circle hover-img">
                                        <div class="collection_image img-style">
                                    <img class="lazyload" src="~/images/intention/@item.IntentionImageUrl" data-src="./images/intention/@item.IntentionImageUrl"
                                                alt="@item.IntentionName">
                                        </div>
                                        <div class="collection_content">
                                            <p class="collection_name h4 link">@item.IntentionName</p>
                                        </div>
                                    </a>
                                </div>
                            }
                        }
                       
                    </div>
                    <div class="sw-dot-default tf-sw-pagination"></div>
                </div>
            </div>
        </section>
<!-- /Shop By Intention -->

<!-- Featured -->
<section class="flat-spacing">
    <div class="container-full">
        <h2 class="h1 sect-title text-black fw-medium text-center wow fadeInUp">Featured Products</h2>
        <div class="row">
            <div class="col-xl-4">
                <div class="box-image_V01 lookbook hover-img mb-xl-0 wow fadeInUp">
                    <a class="box-image_image img-style" asp-page="/productlist">
                        <img src="images/section/1.jpg" data-src="images/section/1.jpg" alt="Image"
                             class="lazyload">
                    </a>
                    <div class="box-image_content">
                        <a class="title text-display fw-semibold text-white link" asp-page="/productlist">Lookbook</a>
                        <span class="sub-title h5 text-white">@(Model.Products?.Count() ?? 0) product</span>
                        <a class="tf-btn-line style-white" asp-page="/productlist"> EXPLORE NOW </a>
                    </div>
                </div>
            </div>
            <div class="col-xl-8">
                <div dir="ltr" class="fp-slidder swiper tf-swiper wrap-sw-over wow fadeInUp" data-preview="3"
                     data-tablet="3" data-mobile-sm="2" data-mobile="2" data-space-lg="20" data-space-md="15"
                     data-space="12" data-pagination="2" data-pagination-sm="2" data-pagination-md="3"
                     data-pagination-lg="3">
                    <div class="swiper-wrapper">
                        @if (Model.ByCategory != null && Model.ByCategory.Any())
                        {
                            @foreach (var item in Model.ByCategory.Take(4))
                            {
                                <div class="swiper-slide">
                                    <div class="card-product">
                                        <div class="card-product_wrapper">
                                            <a asp-page="/detail" asp-route-skucode="@item.SkuCode" asp-route-productname="@item.ParentUrl" class="product-img">
                                                <img class="lazyload img-product"
                                                     src="/images/products/@item.Thumbnail"
                                                     data-src="/images/products/@item.Thumbnail" alt="@item.ProductName">
                                                <img class="lazyload img-hover" src="/images/products/@item.Thumbnail"
                                                     data-src="/images/products/@item.Thumbnail" alt="@item.ProductName">
                                            </a>
                                            <ul class="product-action_list">
                                                <li>
                                                    <form method="post" asp-page="/Index" asp-page-handler="AddToCart">
                                                        <input type="hidden" name="SkuCode" value="@item.SkuCode" />
                                                        <input type="hidden" name="ProductName" value="@item.ProductName" />
                                                        <input type="hidden" name="Qty" value="1" />
                                                        <input type="hidden" name="Price" value="@item.Price" />
                                                        <button type="submit" class="hover-tooltip tooltip-left box-icon">
                                                            <span class="icon icon-shopping-cart-simple"></span>
                                                            <span class="tooltip">Add to cart</span>
                                                        </button>
                                                    </form>
                                                </li>
                                                <li class="wishlist">
                                                    <form method="post" asp-page="/Index" asp-page-handler="AddToWishlist">
                                                        <input type="hidden" name="SkuCode" value="@item.SkuCode" />
                                                        <input type="hidden" name="ProductName" value="@item.ProductName" />
                                                        <input type="hidden" name="buynow" value="false" />
                                                        <button type="submit" class="hover-tooltip tooltip-left box-icon">
                                                            <span class="icon icon-heart"></span>
                                                            <span class="tooltip">Add To Wishlist</span>
                                                        </button>
                                                    </form>
                                                </li>
                                            </ul>
                                            <ul class="product-badge_list">
                                                <li class="product-badge_item h6 hot">@item.ProductName</li>
                                            </ul>
                                        </div>
                                        <div class="card-product_info">
                                            <a asp-page="/detail" asp-route-skucode="@item.SkuCode" asp-route-productname="@item.ParentUrl" class="name-product h4 link">
                                                @item.ProductName
                                            </a>
                                            <div class="price-wrap">
                                                <span class="price-new h6">₹@item.Price</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                       
                    </div>
                    <div class="sw-dot-default tf-sw-pagination">
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- /Featured -->

