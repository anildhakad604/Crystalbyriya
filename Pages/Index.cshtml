<!-- Blog -->
<section class="flat-spacing">
    <div class="container">
        <h2 class="h1 sect-title text-black fw-medium text-center wow fadeInUp">Read Our Blog</h2>
        <div dir="ltr" class="swiper tf-swiper" data-preview="4" data-tablet="3" data-mobile-sm="2"
             data-mobile="1" data-space-lg="48" data-space-md="24" data-space="12" data-pagination="1"
             data-pagination-sm="2" data-pagination-md="3" data-pagination-lg="4">
            <div class="swiper-wrapper">
                @if (Model.Blogs != null && Model.Blogs.Any())
                {
                    @foreach (var item in Model.Blogs)
                    {
                        var blogRouteUrl = string.IsNullOrWhiteSpace(item.CustomUrl) ? item.BlogTitle : item.CustomUrl;
                        var blogDetailUrl = Url.Page("/blogdetail", new { blogid = item.Blogid, url = blogRouteUrl }) ?? "/blog";
                        <div class="swiper-slide">
                            <div class="article-blog type-space-2 hover-img4 wow fadeInLeft">
                                <a href="@blogDetailUrl" class="entry_image img-style4">
                                    <img src="images/blog/@item.Image" data-src="images/blog/@item.Image" alt="@item.BlogTitle"
                                         class="lazyload aspect-ratio-0">
                                </a>
                                <div class="entry_tag">
                                    <a href="/blog" class="name-tag h6 link">
                                        @item.PublishedDate.ToString("MMMM dd, yyyy")
                                    </a>
                                </div>

                                <div class="blog-content">
                                    <a href="@blogDetailUrl" class="entry_name link h4">
                                        @(string.IsNullOrEmpty(item.BlogTitle) ? "No Title Available" : item.BlogTitle)
                                    </a>
                                    <p class="text h6">
                                        @(string.IsNullOrEmpty(item.ShortDescription) ? "No description available." : item.ShortDescription)
                                    </p>
                                    <a href="@blogDetailUrl" class="tf-btn-line"> Read more </a>
                                </div>
                            </div>
                        </div>
                    }
                }
                
            </div>
            <div class="sw-dot-default tf-sw-pagination"></div>
        </div>
    </div>
</section>
<!-- /Blog -->
<!-- Gallery -->
<section class="flat-spacing pt-0">
    <div class="container">
        @{
            var instagramProfileUrl = "https://www.instagram.com/drastrocrystals";
        }
        <div class="sect-title text-center wow fadeInUp">
            <h2 class="h1 title mb-16">Follow Us On Instagram</h2>
            <h6>
                @@drastrocrystals: <span class="text-main fw-normal">Follow us and get</span> 10% off coupon
            </h6>
        </div>

        <div dir="ltr" class="swiper tf-swiper wow fadeInUp" data-preview="4" data-tablet="3" data-mobile-sm="2"
             data-mobile="2" data-space="0" data-pagination="2" data-pagination-sm="2" data-pagination-md="3"
             data-pagination-lg="4">
            <div class="swiper-wrapper">
                <!-- item 1 -->
                        @if (Model.Instagrams != null && Model.Instagrams.Any())
                        {
                @foreach (var item in Model.Instagrams.Take(8))
                {
                    <div class="swiper-slide">
                        <div class="gallery-item hover-img hover-overlay">
                            <div class="image img-style">
                                            <img class="lazyload" src="@(string.IsNullOrEmpty(item.InstagramUrl) ? "/images/gallery/default.jpg" : "/images/gallery/" + item.InstagramUrl)" data-src="@(string.IsNullOrEmpty(item.InstagramUrl) ? "/images/gallery/default.jpg" : "/images/gallery/" + item.InstagramUrl)"
                                alt="Image">
                            </div>
                                        <a href="@instagramProfileUrl" target="_blank" class="box-icon hover-tooltip">
                                <span class="icon icon-instagram-logo"></span>
                                <span class="tooltip">View on Instagram</span>
                            </a>
                        </div>
                    </div>
                            }
                }
            </div>
            <div class="sw-dot-default tf-sw-pagination"></div>
        </div>
    </div>
</section>
<!-- /Gallery -->
