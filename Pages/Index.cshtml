                                                    <li class="product-badge_item h6 hot">
                                                        @(string.IsNullOrEmpty(item.Tags) ? "Trending" : item.Tags)
                                                    </li>
                                                </ul>
                                            </div>
                                            <div class="card-product_info">
                                                <a asp-page="/detail" asp-route-skucode="@item.SkuCode" asp-route-productname="@item.ParentUrl" class="name-product h4 link">
                                                    @item.ProductName
                                                </a>
                                                <div class="price-wrap">
                                                    <span class="price-new h6">₹@item.Price</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                            <div class="sw-dot-default tf-sw-pagination"></div>
                        </div>
                    </div>
