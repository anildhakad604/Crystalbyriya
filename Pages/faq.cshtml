    <link rel="canonical" href="https://www.drastrocrystals.com/faq" />
    <meta property="og:title" content="FAQ | Dr Astro Crystals" />
    <meta property="og:url" content="https://www.drastrocrystals.com/faq" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://djelgxoby50a9.cloudfront.net/logo/logo.png" />
    <meta property="og:site_name" content="https://www.drastrocrystals.com" />
    <meta name="twitter:card" content="summary">
    <meta name="twitter:site" content="https://www.drastrocrystals.com">
