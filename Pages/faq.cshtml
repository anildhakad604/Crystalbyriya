<!-- Page Title -->
<section class="s-page-title">
    <div class="container">
        <div class="content">
            <h1 class="title-page">Frequently Asked Questions</h1>
            <ul class="breadcrumbs-page">
                <li><a asp-page="/Index" class="h6 link">Home</a></li>
                <li class="d-flex"><i class="icon icon-caret-right"></i></li>
                <li>
                    <h6 class="current-page fw-normal">FAQ</h6>
                </li>
            </ul>
        </div>
    </div>
</section>
<!-- /Page Title -->

<!-- FAQ -->
<section class="flat-spacing">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="sect-title text-center mb-40">
                    <h2 class="h1">We're Here to Help</h2>
                    <p class="h6 mt-12 text-main-2">Find answers to the most common questions about our products, orders, and services.</p>
                </div>

                <div class="accordion" id="faqAccordion">
                    <!-- Orders & Payment -->
                    <div class="mb-4">
                        <h3 class="h5 fw-semibold mb-3">🛒 Orders &amp; Payment</h3>
                        <div class="accordion-item">
                            <h4 class="accordion-header" id="faq1">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faqBody1" aria-expanded="true" aria-controls="faqBody1">
                                    Do you offer Cash on Delivery (COD)?
                                </button>
                            </h4>
                            <div id="faqBody1" class="accordion-collapse collapse show" aria-labelledby="faq1" data-bs-parent="#faqAccordion">
                                <div class="accordion-body h6 text-main">
                                    Yes, we offer COD. However, a small prepayment amount is required at the time of placing the order to confirm it. This helps us reduce cancellations and ensures your order is processed smoothly.
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h4 class="accordion-header" id="faq2">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faqBody2" aria-expanded="false" aria-controls="faqBody2">
                                    What payment methods do you accept?
                                </button>
                            </h4>
                            <div id="faqBody2" class="accordion-collapse collapse" aria-labelledby="faq2" data-bs-parent="#faqAccordion">
                                <div class="accordion-body h6 text-main">
                                    We accept all major payment methods including UPI (PhonePe, GPay, Paytm), Credit/Debit Cards (Visa, Mastercard), Net Banking, and Cash on Delivery for eligible pin codes.
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h4 class="accordion-header" id="faq3">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faqBody3" aria-expanded="false" aria-controls="faqBody3">
                                    How do I cancel my order?
                                </button>
                            </h4>
                            <div id="faqBody3" class="accordion-collapse collapse" aria-labelledby="faq3" data-bs-parent="#faqAccordion">
                                <div class="accordion-body h6 text-main">
                                    <ol>
                                        <li>Login to your account on our website.</li>
                                        <li>Go to your "Account" tab and click on "Orders".</li>
                                        <li>Select the order and click on "Cancel Request".</li>
                                        <li>Fill in the cancellation form with your reason.</li>
                                        <li>Click "Confirm Cancellation".</li>
                                    </ol>
                                    <strong>Note:</strong> Orders can only be cancelled within 48 hours of purchase and before they are dispatched.
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Shipping & Delivery -->
                    <div class="mb-4">
                        <h3 class="h5 fw-semibold mb-3">🚚 Shipping &amp; Delivery</h3>
                        <div class="accordion-item">
                            <h4 class="accordion-header" id="faq4">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faqBody4" aria-expanded="false" aria-controls="faqBody4">
                                    When will I receive my order?
                                </button>
                            </h4>
                            <div id="faqBody4" class="accordion-collapse collapse" aria-labelledby="faq4" data-bs-parent="#faqAccordion">
                                <div class="accordion-body h6 text-main">
                                    Standard delivery within India typically takes <strong>5–7 business days</strong> after dispatch. For remote areas, it may take up to 10 business days. International orders are shipped within 10–15 business days.
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h4 class="accordion-header" id="faq5">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faqBody5" aria-expanded="false" aria-controls="faqBody5">
                                    Is free shipping available?
                                </button>
                            </h4>
                            <div id="faqBody5" class="accordion-collapse collapse" aria-labelledby="faq5" data-bs-parent="#faqAccordion">
                                <div class="accordion-body h6 text-main">
                                    Yes! We offer <strong>free standard shipping</strong> on all orders above ₹3,000. Orders below this amount have a flat shipping charge of ₹80.
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h4 class="accordion-header" id="faq6">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faqBody6" aria-expanded="false" aria-controls="faqBody6">
                                    How do you ensure safe product delivery?
                                </button>
                            </h4>
                            <div id="faqBody6" class="accordion-collapse collapse" aria-labelledby="faq6" data-bs-parent="#faqAccordion">
                                <div class="accordion-body h6 text-main">
                                    All our crystals and gemstones are carefully packed in multiple protective layers with cushioning material. Fragile items are also wrapped in bubble wrap and placed in rigid boxes to ensure they arrive in perfect condition.
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Returns & Exchanges -->
                    <div class="mb-4">
                        <h3 class="h5 fw-semibold mb-3">🔁 Returns &amp; Exchanges</h3>
                        <div class="accordion-item">
                            <h4 class="accordion-header" id="faq7">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faqBody7" aria-expanded="false" aria-controls="faqBody7">
                                    What is your return policy?
                                </button>
                            </h4>
                            <div id="faqBody7" class="accordion-collapse collapse" aria-labelledby="faq7" data-bs-parent="#faqAccordion">
                                <div class="accordion-body h6 text-main">
                                    We accept returns within <strong>7 days</strong> of delivery for damaged or defective items. The product must be unused, in its original packaging, and accompanied by proof of purchase and an unboxing video. Custom orders are non-returnable.
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h4 class="accordion-header" id="faq8">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faqBody8" aria-expanded="false" aria-controls="faqBody8">
                                    Are crystals and gemstones authentic / natural?
                                </button>
                            </h4>
                            <div id="faqBody8" class="accordion-collapse collapse" aria-labelledby="faq8" data-bs-parent="#faqAccordion">
                                <div class="accordion-body h6 text-main">
                                    Yes! All our crystals and gemstones are 100% natural and ethically sourced. We do not sell synthetic or lab-created stones. Each product is carefully selected by our experts for quality and energetic properties.
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Support -->
                    <div class="mb-4">
                        <h3 class="h5 fw-semibold mb-3">💬 Support</h3>
                        <div class="accordion-item">
                            <h4 class="accordion-header" id="faq9">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faqBody9" aria-expanded="false" aria-controls="faqBody9">
                                    How can I contact your team?
                                </button>
                            </h4>
                            <div id="faqBody9" class="accordion-collapse collapse" aria-labelledby="faq9" data-bs-parent="#faqAccordion">
                                <div class="accordion-body h6 text-main">
                                    You can reach us via:
                                    <ul class="mt-2">
                                        <li>📧 Email: <a href="mailto:Info@drastrocrystals.com" class="link">Info@drastrocrystals.com</a></li>
                                        <li>📱 WhatsApp: <a href="https://wa.me/919876543210" target="_blank" class="link">+91 98765 43210</a></li>
                                        <li>📸 Instagram: <a href="https://www.instagram.com/drastrocrystals" target="_blank" class="link">@@drastrocrystals</a></li>
                                    </ul>
                                    Our support team is available Monday–Saturday, 10am to 6pm IST.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- CTA -->
                <div class="text-center mt-40">
                    <p class="h6 mb-12">Still have questions? We're happy to help!</p>
                    <a asp-page="/contactus" class="tf-btn animate-btn">
                        Contact Us
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- /FAQ -->