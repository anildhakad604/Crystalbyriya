<main class="main-content">
    <!--== Start Page Title Area ==-->
    <div class="page-title-area page-title-area2">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="page-title-content content-style-2">
                        <div class="bread-crumbs"><a asp-page="Index">Home<span class="breadcrumb-sep">&gt;</span></a><a asp-page="/rewards">Rewards</a></div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-lg-12 m-auto">
                    <div class="section-title text-center mb-2">
                        <h2 class="title">Share and earn more now in just 4 easy steps </h2>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!--== End Page Title Area ==-->
    <!--== Start Products Area Wrapper ==-->
    <section class="rewards-page-area area-padding pt-3 pt-md-5">
        <div class="container">
            <div class="row gy-3 justify-content-center">
                <div class="col-6 col-md-4 col-lg-3">
                    <a href="javascript:void(0)" class="rewards-step-parent">
                        <div class="rewards-step-inner text-center">
                            <div class="icon-parent">
                                <i class="lastudioicon lastudioicon-b-instagram"></i>
                            </div>
                            <div class="rewards-step-footer">
                                <p>Follow us on Instagram</p>
                                <h6 class="fw-bold">Step-1</h6>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-6 col-md-4 col-lg-3">
                    <a href="javascript:void(0)" class="rewards-step-parent">
                        <div class="rewards-step-inner text-center">
                            <div class="icon-parent">
                                <i class="lni lni-youtube"></i>
                            </div>
                            <div class="rewards-step-footer">
                                <p>Subscribe on youtube</p>
                                <h6 class="fw-bold">Step-2</h6>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-6 col-md-4 col-lg-3">
                    <a href="javascript:void(0)" class="rewards-step-parent">
                        <div class="rewards-step-inner text-center">
                            <div class="icon-parent">
                                <i class="lni lni-image"></i>
                            </div>
