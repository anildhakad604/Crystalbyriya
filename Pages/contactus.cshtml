<!-- Contact Form -->
<section class="s-contact-form flat-spacing">
    <div class="container">
        <div class="sect-title text-center">
            <p class="h1 title mb-8">Contact Form</p>
            <p class="s-subtitle h6">Contact us using the form below, we will contact you as soon as possible</p>
        </div>
        <form method="post" class="form-contact-2" autocomplete="off">
            @if (!ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
            {
                <div class="alert alert-danger" role="alert">
                    @foreach (var error in ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <p>@error.ErrorMessage</p>
                    }
                </div>
            }
            
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success" role="alert">
                    @TempData["SuccessMessage"]
                </div>
            }
            
            <div class="form-content">
                <div class="tf-grid-layout md-col-3">
                    <fieldset>
                        <input type="text" asp-for="contactus.Name" placeholder="Your name" required="">
                        <span asp-validation-for="contactus.Name" class="text-danger"></span>
                    </fieldset>
                    <fieldset>
                        <input type="tel" asp-for="contactus.Phonenumber" placeholder="Your phone number" required="">
                        <span asp-validation-for="contactus.Phonenumber" class="text-danger"></span>
                    </fieldset>
                    <fieldset>
                        <input type="email" asp-for="contactus.Email" placeholder="Your email" required="">
                        <span asp-validation-for="contactus.Email" class="text-danger"></span>
                    </fieldset>
                </div>
                <textarea asp-for="contactus.Message" placeholder="Your message" rows="5" required=""></textarea>
                <span asp-validation-for="contactus.Message" class="text-danger"></span>
            </div>
            <div class="form-action">
                <button type="submit" class="h6 tf-btn animate-btn">
                    Send message
                </button>
            </div>
        </form>
    </div>
</section>
<!-- /Contact Form -->
