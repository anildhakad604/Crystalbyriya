@page
@model CrystalByRiya.Pages.checkoutModel
@{
}
@section Metatags {
    <title> Crystal By Riya | Pre-Owned Excellence</title>
    <meta name="keywords" content="Healing stones,Crystals and Gemstones,Healing crystals,Natural stones,Authentic crystals,Original crystals,Crystal jewellery,Sterling Silver Jewellery,Silver jewellery crystals,Silver jewellery" />
    <link rel="canonical" href="@Model.Currenturl" />
    <meta property="og:title" content="Crystals By Riya | Home" />
    <meta property="og:url" content="@Model.Currenturl" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://djelgxoby50a9.cloudfront.net/logo/logo.png" />
    <meta property="og:site_name" content="https://www.crystalsbyriya.com" />

    <meta name="twitter:card" content="summary">
    <meta name="twitter:site" content="https://www.crystalsbyriya.com">
    <meta name="twitter:title" content="Epitome Cars | Pre-Owned Excellence">
    <meta name="twitter:description" content="Placing our customers at the core of everything we do, understanding their needs, and exceeding their expectations.">
    <meta name="twitter:creator" content="Crystals by Riya">
    <meta name="twitter:image" content="https://djelgxoby50a9.cloudfront.net/logo/logo.png">
    <meta name="twitter:domain" content="https://www.crystalsbyriya.com" />
}
@{
    double SubTotal = 0;
    double GrandTotal = 0;
}






<main class="main-content">
    <!--== Start Page Title Area ==-->

    <div class="page-title-area page-title-area2">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="page-title-content content-style-2">
                        <div class="bread-crumbs"><a asp-page="/">Home<span class="breadcrumb-sep">&gt;</span></a><a href="javascript:void(0)">Checkout</a></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!--== End Page Title Area ==-->
    <!--== Start Shop Checkout Area ==-->
    <section class="shop-checkout-area pt-0">
        <div class="container">
            @if (string.IsNullOrEmpty(Model.UserEmail))
            {
                <div class="row">
                    <div class="col-md-12">
                        <div class="shop-return-login" id="returnloginAccordion">
                            <div class="card">
                                <h6>
                                    Returning customer? <span data-bs-toggle="collapse" data-bs-target="#returnloginaccordion"> Click here to login</span>
                                </h6>
                                <div id="returnloginaccordion" class="collapse" data-bs-parent="#returnloginAccordion">
                                    <div class="card-body">
                                        <p>If you have shopped with us before, please enter your details in the boxes below. If you are a new customer, please proceed to the Billing & Shipping section.</p>
                                        <form asp-page-handler="Login" method="post">
                                            <input type="hidden" name="redirectUrl" value="@HttpContext.Request.Query["redirectUrl"]" />
                                            <div class="form-group">
                                                <label for="rl_username">Username or email <span class="required">*</span></label>
                                                <input class="form-control" id="rl_username" type="text" asp-for="register.Email" >
                                            </div>
                                            <div class="form-group">
                                                <label for="rl_password">Password <span class="required">*</span></label>
                                                <input class="form-control" id="rl_password" type="text" asp-for="register.Password">
                                            </div>
                                            <button class="btn btn-coupon w-100">Login</button>
                                            <div class="remember-lostpassword">
                                                <div class="custom-control custom-checkbox">
                                                    <input type="checkbox" class="custom-control-input" id="RadioRememberMe">
                                                    <label class="custom-control-label ps-1" for="RadioRememberMe">Remember me</label>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            }

            <div class="shop-billing-form">
                <form asp-page-handler="PlaceOrder" id="forms" method="post">
                    <input type="hidden" id="paymentMethod" name="paymentMethod" value="" />



                    <div class="row ">
                        <div class="col-lg-8 col-md-12">
                            <div class="shop-billing-form">

                                <h4 class="title">Billing details</h4>
                                <div class="form-group">
                                    <label for="name">Email Id</label>
                                    <input class="form-control" id="name" name="email" type="text" asp-for="Detail.Emailid" required>
                                    <span asp-validation-for="Detail.Emailid" class="text-danger"></span>
                                </div>
                                <div class="form-group">
                                    <label for="name">Full name</label>
                                    <input class="form-control" id="name" type="text" asp-for="Detail.FullName"  required >
                                    <span asp-validation-for="Detail.FullName" class="text-danger"></span>
                                </div>

                                <div class="form-group">
                                    <label for="street_address">Street address </label>
                                    <input class="form-control" id="street_address" type="text" placeholder="House number and street name" asp-for="Detail.Address"  required>
                                    <span asp-validation-for="Detail.Address" class="text-danger"></span>
                                </div>

                                <div class="form-group">
                                    <input class="form-control" type="text" placeholder="Apartment, suite, unit, etc. (optional)" asp-for="Detail.Apartment" >
                                    <span asp-validation-for="Detail.Apartment" class="text-danger"></span>
                                </div>

                                <div class="form-group">
                                    <label for="town_city">Town / City </label>
                                    <input class="form-control" id="town_city" type="text" asp-for="Detail.City"  required >
                                    <span asp-validation-for="Detail.City" class="text-danger"></span>
                                </div>

                                <div class="form-group">
                                    <label for="state_region">State </label>
                                    <select class="form-control niceselect" id="state_region"  asp-for="Detail.State"  required>
                                        <span asp-validation-for="Detail.State" class="text-danger"></span>>
                                        <option value="none" selected hidden></option>
                                        <option value="Andhra Pradesh">Andhra Pradesh</option>
                                        <option value="Andaman and Nicobar Islands">Andaman and Nicobar Islands</option>
                                        <option value="Arunachal Pradesh">Arunachal Pradesh</option>
                                        <option value="Assam">Assam</option>
                                        <option value="Bihar">Bihar</option>
                                        <option value="Chandigarh">Chandigarh</option>
                                        <option value="Chhattisgarh">Chhattisgarh</option>
                                        <option value="Dadar and Nagar Haveli">Dadar and Nagar Haveli</option>
                                        <option value="Daman and Diu">Daman and Diu</option>
                                        <option value="Delhi">Delhi</option>
                                        <option value="Lakshadweep">Lakshadweep</option>
                                        <option value="Puducherry">Puducherry</option>
                                        <option value="Goa">Goa</option>
                                        <option value="Gujarat">Gujarat</option>
                                        <option value="Haryana">Haryana</option>
                                        <option value="Himachal Pradesh">Himachal Pradesh</option>
                                        <option value="Jammu and Kashmir">Jammu and Kashmir</option>
                                        <option value="Jharkhand">Jharkhand</option>
                                        <option value="Karnataka">Karnataka</option>
                                        <option value="Kerala">Kerala</option>
                                        <option value="Madhya Pradesh">Madhya Pradesh</option>
                                        <option value="Maharashtra">Maharashtra</option>
                                        <option value="Manipur">Manipur</option>
                                        <option value="Meghalaya">Meghalaya</option>
                                        <option value="Mizoram">Mizoram</option>
                                        <option value="Nagaland">Nagaland</option>
                                        <option value="Odisha">Odisha</option>
                                        <option value="Punjab">Punjab</option>
                                        <option value="Rajasthan">Rajasthan</option>
                                        <option value="Sikkim">Sikkim</option>
                                        <option value="Tamil Nadu">Tamil Nadu</option>
                                        <option value="Telangana">Telangana</option>
                                        <option value="Tripura">Tripura</option>
                                        <option value="Uttar Pradesh">Uttar Pradesh</option>
                                        <option value="Uttarakhand">Uttarakhand</option>
                                        <option value="West Bengal">West Bengal</option>
                                    </select>
                                </div>

                                <div class="form-group">
                                    <label for="zip">ZIP </label>
                                    <input class="form-control" id="zip" type="text" asp-for="Detail.PinCode"  required >
                                    <span asp-validation-for="Detail.PinCode" class="text-danger"></span>
                                </div>

                                <div class="form-group">
                                    <label for="phone">Phone </label>
                                    <input class="form-control" id="phone" name="Phone" type="text" asp-for="Detail.ContactNumber" required/>
                                    <span asp-validation-for="Detail.ContactNumber" class="text-danger"></span>
                                </div>
                                <div class="checkout-box-wrap ship-different-address">
                                    <div class="form-group">
                                        <div class="custom-control custom-checkbox">
                                            <input type="checkbox" class="custom-control-input" id="ship_to_different"  name="shipment" value="true" onchange="toggleRequiredFields()">
                                            <label class="custom-control-label" for="ship_to_different">Ship to a different address?</label>
                                        </div>
                                    </div>
                                    <div class="ship-to-different single-form-row">

                                        <div class="form-group">
                                            <label for="name">Full name</label>
                                            <input class="form-control" id="name" type="text" asp-for="ShippingDetail.Name" >
                                            <span asp-validation-for="ShippingDetail.Name" class="text-danger"></span>
                                        </div>

                                        <div class="form-group">
                                            <label for="street_address">Street address </label>
                                            <input class="form-control" id="street_address" asp-for="ShippingDetail.Address"  type="text" placeholder="House number and street name" >
                                        </div>

                                        <div class="form-group mt-2">
                                            <input class="form-control" asp-for="ShippingDetail.Apartment" type="text" placeholder="Apartment, suite, unit, etc. (optional)">
                                        </div>

                                        <div class="form-group">
                                            <label for="town_city">Town / City </label>
                                            <input class="form-control" id="town_city"  asp-for="ShippingDetail.City" type="text" >
                                        </div>

                                        <div class="form-group">
                                            <label for="state_region">State </label>
                                            <select class="form-control niceselect" id="state_region" name="state" asp-for="ShippingDetail.State" >
                                                <option value="none" selected hidden></option>
                                                <option value="Andhra Pradesh">Andhra Pradesh</option>
                                                <option value="Andaman and Nicobar Islands">Andaman and Nicobar Islands</option>
                                                <option value="Arunachal Pradesh">Arunachal Pradesh</option>
                                                <option value="Assam">Assam</option>
                                                <option value="Bihar">Bihar</option>
                                                <option value="Chandigarh">Chandigarh</option>
                                                <option value="Chhattisgarh">Chhattisgarh</option>
                                                <option value="Dadar and Nagar Haveli">Dadar and Nagar Haveli</option>
                                                <option value="Daman and Diu">Daman and Diu</option>
                                                <option value="Delhi">Delhi</option>
                                                <option value="Lakshadweep">Lakshadweep</option>
                                                <option value="Puducherry">Puducherry</option>
                                                <option value="Goa">Goa</option>
                                                <option value="Gujarat">Gujarat</option>
                                                <option value="Haryana">Haryana</option>
                                                <option value="Himachal Pradesh">Himachal Pradesh</option>
                                                <option value="Jammu and Kashmir">Jammu and Kashmir</option>
                                                <option value="Jharkhand">Jharkhand</option>
                                                <option value="Karnataka">Karnataka</option>
                                                <option value="Kerala">Kerala</option>
                                                <option value="Madhya Pradesh">Madhya Pradesh</option>
                                                <option value="Maharashtra">Maharashtra</option>
                                                <option value="Manipur">Manipur</option>
                                                <option value="Meghalaya">Meghalaya</option>
                                                <option value="Mizoram">Mizoram</option>
                                                <option value="Nagaland">Nagaland</option>
                                                <option value="Odisha">Odisha</option>
                                                <option value="Punjab">Punjab</option>
                                                <option value="Rajasthan">Rajasthan</option>
                                                <option value="Sikkim">Sikkim</option>
                                                <option value="Tamil Nadu">Tamil Nadu</option>
                                                <option value="Telangana">Telangana</option>
                                                <option value="Tripura">Tripura</option>
                                                <option value="Uttar Pradesh">Uttar Pradesh</option>
                                                <option value="Uttarakhand">Uttarakhand</option>
                                                <option value="West Bengal">West Bengal</option>
                                            </select>
                                        </div>

                                        <div class="form-group">
                                            <label for="zip">ZIP </label>
                                            <input class="form-control" id="zip" type="text" asp-for="ShippingDetail.PinCode"  >
                                            <span asp-validation-for="ShippingDetail.PinCode" class="text-danger"></span>
                                        </div>

                                        <div class="form-group">
                                            <label for="phone">Phone </label>
                                            <input class="form-control" id="phone" type="text" asp-for="ShippingDetail.ContactNumber"  />
                                            <span asp-validation-for="ShippingDetail.ContactNumber" class="text-danger"></span>
                                        </div>

                                        <div class="form-group">
                                            <label for="email">Email address </label>
                                            <input class="form-control" id="email" type="text" asp-for="ShippingDetail.Emailid" >
                                            <span asp-validation-for="ShippingDetail.Emailid" class="text-danger"></span>
                                        </div>

                                    </div>
                                </div>

                                <div class="form-group">
                                    <label for="order_notes">Order notes (optional)</label>
                                    <textarea class="form-control" name="comment" id="order_notes" placeholder="Notes about your order, e.g. special notes for delivery."></textarea>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-4 col-md-12">
                            <h4 class="title">Your order</h4>
                            <div class="order-review-details">
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th>Product</th>
                                            <th>Subtotal</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{
                                            double cartSubTotal = 0;  // Declare cartSubTotal outside the @if block to make it accessible later
                                        }

                                        @if (Model.Carts.Count>0)
                                        {
                                            foreach (var item in Model.Carts)
                                            {
                                            // Calculate subtotal for each item
                                                double itemSubTotal = item.Price * item.Qty;
                                                cartSubTotal += itemSubTotal;  // Accumulate subtotal for all items

                                                <tr>
                                                    <td>
                                                        <span class="product-title">@item.ProductName</span>
                                                        <span class="product-quantity"> × @item.Qty</span>
                                                    </td>
                                                    <td>&#8377; @itemSubTotal</td>  <!-- Display item subtotal -->
                                                </tr>
                                            }

                                            <tr>
                                                <td><strong>Subtotal:</strong></td>
                                                <td><strong>&#8377; @cartSubTotal</strong></td>  <!-- Use renamed cartSubTotal -->
                                            </tr>
                                        }

                                        else if (Model.childskuCodes.Count>0){

                                            foreach (var item in Model.childskuCodes){



                                                // Calculate subtotal for each item
                                                double itemSubTotal = item.Price * item.Quantity;
                                                cartSubTotal += itemSubTotal;  // Accumulate subtotal for all items

                                                <tr>
                                                    <td>
                                                        <span class="product-title">item.Product</span>
                                                        <span class="product-quantity"> × item.Quantity</span>
                                                    </td>
                                                    <td>&#8377; @itemSubTotal</td>  <!-- Display item subtotal -->
                                                </tr>


                                                <tr>
                                                    <td><strong>Subtotal:</strong></td>
                                                    <td><strong>&#8377; @cartSubTotal</strong></td>  <!-- Use renamed cartSubTotal -->
                                                </tr>
                                            }
                                        }
                                        @if(Model.Carts.Count==0 && Model.childskuCodes.Count==0)
                                        {
                                            <p> Your cart is empty </p>
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr class="cart-subtotal">
                                            <th>AfterDiscount</th>
                                            <td>&#8377; @Model.AfterDiscount</td>  <!-- Use renamed cartSubTotal -->
                                        </tr>
                                        <tr class="shipping">
                                            <th class="shipping-title">Shipping Charges</th>
                                            <td class="shipping-check">
                                                <div class="ship-charge">
                                                    <p>&#8377; @Model.shipping</p>  <!-- Display the shipping charges -->
                                                </div>
                                            </td>
                                        </tr>
                                        @* Calculate final total using cartSubTotal, GST, and shipping *@
                                        @{
                                            double finalTotal;

                                            if (Model.AfterDiscount > 0)
                                            {
                                                finalTotal = Model.AfterDiscount + Model.shipping;
                                            }
                                            else
                                            {
                                                finalTotal = cartSubTotal + Model.shipping;
                                            }
                                        }
                                        <tr class="final-total">
                                            <th>Total</th>
                                            <td><span class="total-amount">&#8377; @finalTotal</span></td> <!-- Display the final total -->
                                        </tr>
                                        <input type="hidden" id="hiddenTotal" name="amount" value="@finalTotal" />

                                    </tfoot>
                                </table>

                                <div class="shop-payment-method">
                                    <div class="title pb-0 mb-3">
                                        <h5 class="fw-semibold">Payment Method</h5>
                                    </div>
                                    <div id="accordion">

                                       

                                        <div class="card">
                                            <div class="card-header" id="card_payment">
                                                <h5 class="title" data-bs-toggle="collapse" data-bs-target="#itemTwo" aria-controls="itemTwo" aria-expanded="false">Online Payment</h5>
                                            </div>
                                            <div id="itemTwo" class="collapse" aria-labelledby="card_payment" data-bs-parent="#accordion">
                                            </div>
                                        </div>

                                        <div class="card">
                                            <div class="card-header" id="cash_on_delivery">
                                                <h5 class="title" data-bs-toggle="collapse" data-bs-target="#itemThree" aria-controls="itemThree" aria-expanded="false">Cash on delivery</h5>
                                            </div>
                                            <div id="itemThree" class="collapse" aria-labelledby="cash_on_delivery" data-bs-parent="#accordion">
                                                <div class="card-body">
                                                    <p>Extra Charge of Rs 200 applicable on COD orders, Prepay to confirm</p>
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>
                            <div class="shop-checkout-info">
                                <div class="form-group">
                                    <label for="privacyCheck"><input type="checkbox" name="privacyCheck" id="privacyCheck" checked> Your personal data will be used to process your order, support your experience throughout this website, and for other purposes described in our privacy policy.</label>
                                </div>
                            </div>
                            
                                <button class="btn place-order-btn" type="submit" onclick="return validatePaymentMethod();">Place order</button>
                            
                        </div>
                    </div>
                </form>
            </div>
            
        </div>
    </section>
    <!--== End Shop Checkout Area ==-->


</main>
<script src="https://djelgxoby50a9.cloudfront.net/assetsv2/js/CheckoutPage.js">


</script>