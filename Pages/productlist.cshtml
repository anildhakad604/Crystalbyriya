@page "{catname?}/{subcatname?}"
<script>
    const catname = "@(Request.RouteValues["catname"] ?? "")";
    const subcatname = "@(Request.RouteValues["subcatname"] ?? "")";
</script>

@model CrystalByRiya.Pages.productlistModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@using Microsoft.AspNetCore.Http
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    string userEmail = HttpContextAccessor.HttpContext.Session.GetString("UserEmail");
    var productlist = Model.PagedProducts;
    var bestsellers = Model.SpBestseller;
}



