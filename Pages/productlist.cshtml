                        </div>
                    </div>
                </div>
            }
            else
            {

                <div class="row">
                    <div class="col-lg-12">
                        <div class="page-title-content content-style-2">
                            <div class="bread-crumbs"><a href="/Index">Home<span class="breadcrumb-sep">&gt;</span></a><a href="javascript:void(0)">Product List</a></div>
                        </div>
                    </div>
                </div>
            }
            <div class="row">
                <div class="col-lg-12 m-auto">
