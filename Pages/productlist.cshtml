@page "{catname?}"
@model CrystalByRiya.Pages.productlistModel
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@using Microsoft.AspNetCore.Http
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    string userEmail = HttpContextAccessor.HttpContext.Session.GetString("UserEmail");
    var productlist = Model.PagedProducts;
    var bestsellers = Model.SpBestseller;
    var currentPage = Model.CurrentPage;
    var totalPages = Model.TotalPages;
    var catname = Request.RouteValues["catname"]?.ToString();
}

@section Metatags {
    <title> Dr Astro Crystals | @Model.CurrentCategoryName </title>
    <meta name="keywords" content="Healing stones,Crystals and Gemstones,Healing crystals,Natural stones,Authentic crystals,Original crystals,Crystal jewellery,Sterling Silver Jewellery,Silver jewellery crystals,Silver jewellery" />
    <link rel="canonical" href="@Model.Currenturl" />
    <meta property="og:title" content="Dr Astro Crystals | @Model.CurrentCategoryName" />
    <meta property="og:url" content="@Model.Currenturl" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://djelgxoby50a9.cloudfront.net/logo/logo.png" />
    <meta property="og:site_name" content="https://www.drastrocrystals.com" />

    <meta name="twitter:card" content="summary">
    <meta name="twitter:site" content="https://www.drastrocrystals.com">
    <meta name="twitter:title" content="Dr Astro Crystals | @Model.CurrentCategoryName">
    <meta name="twitter:description" content="Placing our customers at the core of everything we do, understanding their needs, and exceeding their expectations.">
    <meta name="twitter:creator" content="Dr Astro Crystals">
    <meta name="twitter:image" content="https://djelgxoby50a9.cloudfront.net/logo/logo.png">
    <meta name="twitter:domain" content="https://www.drastrocrystals.com" />
}

<style>
    .tf-pagination-list {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        list-style: none;
        padding: 0;
        margin: 0;
        flex-wrap: wrap;
    }

    .tf-pagination-list li {
        display: block;
    }

    .pagination-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 40px;
        height: 40px;
        padding: 0 12px;
    }
</style>

<!-- Page Title -->
<section class="s-page-title position-relative">
    <div class="container">
        <div class="content position-relative" style="min-height: 220px;">
            @if (Model.CategoryBanner != null && !string.IsNullOrEmpty(Model.CategoryBanner.BannerImage))
            {
                <img src="~/images/banner/@Model.CategoryBanner.BannerImage"
                     data-src="/images/banner/@Model.CategoryBanner.BannerImage"
                     alt="@Model.CategoryBanner.BannerName"
                     class="category-banner-img w-100"
                     style="display:block; min-height:220px; object-fit:cover;" />
                <div style="position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; z-index:2;">
                    <h1 class="title-page mb-0 text-white">@Model.CurrentCategoryName</h1>
                    <ul class="breadcrumbs-page mb-0">
                        <li><a asp-page="/Index" class="h6 link text-white">Home</a></li>
                        <li class="d-flex"><i class="icon icon-caret-right"></i></li>
                        <li>
                            <h6 class="current-page fw-normal text-white">@Model.CurrentCategoryName</h6>
                        </li>
                    </ul>
                </div>
            }
            else
            {
                <h1 class="title-page">@Model.CurrentCategoryName</h1>
                <ul class="breadcrumbs-page">
                    <li><a asp-page="/Index" class="h6 link">Home</a></li>
                    <li class="d-flex"><i class="icon icon-caret-right"></i></li>
                    <li>
                        <h6 class="current-page fw-normal">@Model.CurrentCategoryName</h6>
                    </li>
                </ul>
            }
        </div>
    </div>
</section>
<section class="pt-5">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center text-black">
                <p class="mb-0 h5">@Model.CurrentCategoryDescription</p>
            </div>
        </div>
    </div>
</section>
<!-- /Page Title -->
<!-- Section Product -->
<div class="flat-spacing pt-5">
    <div class="container">
        <div class="tf-shop-control">
            <div class="tf-control-filter">
                <a href="#filterShop" data-bs-toggle="offcanvas" aria-controls="filterShop" class="tf-btn-filter">
                    <span class="icon icon-filter"></span><span class="text">Filter</span>
                </a>
            </div>
            <div class="tf-control-sorting">
                <p class="h6 d-none d-lg-block">Sort by:</p>
                <form method="post" asp-page-handler="Filter" asp-route-catname="@catname">
                    <div class="tf-dropdown-sort" data-bs-toggle="dropdown">
                        <div class="btn-select">
                            <span class="text-sort-value">Sort</span>
                            <span class="icon icon-caret-down"></span>
                        </div>
                        <div class="dropdown-menu">
                            <button type="submit" name="ascedingprice" value="true" class="select-item">
                                Price low to high
                            </button>
                            <button type="submit" name="descendingprice" value="true" class="select-item">
                                Price high to low
                            </button>
                            <button type="submit" name="popularity" value="true" class="select-item">
                                Popularity
                            </button>
                            <button type="submit" name="rating" value="true" class="select-item">
                                Rating
                            </button>
                            <button type="submit" name="latest" value="true" class="select-item">
                                Latest
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
        <div class="wrapper-control-shop gridLayout-wrapper">
            <div class="meta-filter-shop">
                <div id="product-count-grid" class="count-text">Showing @productlist.Count result@(productlist.Count == 1 ? string.Empty : "s") of @Model.TotalProductCount total</div>
                <div id="applied-filters"></div>
                <button id="remove-all" class="remove-all-filters" style="display: none;"><i class="icon icon-close"></i> Clear all</button>
            </div>
            <div class="tf-list-layout wrapper-shop" id="listLayout" style="display: none;">
                @if (productlist.Any())
                {
                    @foreach (var item in  productlist)
                    {
                        <div class="card-product product-style_list" data-availability="In stock" data-brand="automet">
                            <div class="card-product_wrapper">
                                <a asp-page="/detail" asp-route-skucode="@item.Skucode" asp-route-productname="@item.ParentUrl" class="product-img">
                                    <img class="lazyload img-product" src="~/images/products/@item.Thumbnail" alt="@item.ProductName">
                                    <img class="lazyload img-hover" src="~/images/products/@item.Thumbnail" alt="@item.ProductName">
                                </a>
                            </div>
                            <div class="card-product_info">
                                <div class="product-info_list">
                                    <a asp-page="/detail" asp-route-skucode="@item.Skucode" asp-route-productname="@item.ParentUrl" class="name-product h3 link">
                                        @item.ProductName
                                    </a>
                                    <span class="price-new">₹@item.Price</span>
                                </div>
                                
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="text-center py-5">
                            <h3>No products found</h3>
                            <p class="mb-4">Try another category or explore our latest collection.</p>
                            <a asp-page="/Index" class="tf-btn animate-btn">Continue Shopping</a>
                        </div>
                    </div>
                }
            </div>
            <div class="wrapper-shop tf-grid-layout tf-col-4" id="gridLayout">
                @if (productlist.Any())
                {
                    @foreach (var item in productlist)
                    {
                        <div class="card-product grid" data-availability="In stock" data-brand="fisoew">
                            <div class="card-product_wrapper">
                                <a asp-page="/detail" asp-route-skucode="@item.Skucode" asp-route-productname="@item.ParentUrl" class="product-img">
                                    <img class="lazyload img-product" src="~/images/products/@item.Thumbnail" alt="@item.ProductName">
                                    <img class="lazyload img-hover" src="~/images/products/@item.Thumbnail" alt="@item.ProductName">
                                </a>
                                
                            </div>
                            <div class="card-product_info">
                                <a asp-page="/detail" asp-route-skucode="@item.Skucode" asp-route-productname="@item.ParentUrl" class="name-product h4 link">
                                    @item.ProductName
                                </a>
                                <div class="price-wrap">
                                    <span class="price-new h6">₹@item.Price</span>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="text-center py-5">
                            <h3>No products found</h3>
                            <p class="mb-4">Try another category or explore our latest collection.</p>
                            <a asp-page="/Index" class="tf-btn animate-btn">Continue Shopping</a>
                        </div>
                    </div>
                }
            </div>
            @if (totalPages > 1)
            {
                <div class="tf-pagination-wrap d-flex justify-content-center mt-40">
                    <ul class="tf-pagination-list">
                        @if (currentPage > 1)
                        {
                            <li>
                                <a asp-page="/productlist" asp-route-catname="@catname" asp-route-currentPage="@(currentPage - 1)" class="pagination-link">
                                    <i class="icon icon-arrow-left"></i>
                                </a>
                            </li>
                        }
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <li>
                                <a asp-page="/productlist" asp-route-catname="@catname" asp-route-currentPage="@i" class="pagination-link @(i == currentPage ? "active" : "")">@i</a>
                            </li>
                        }
                        @if (currentPage < totalPages)
                        {
                            <li>
                                <a asp-page="/productlist" asp-route-catname="@catname" asp-route-currentPage="@(currentPage + 1)" class="pagination-link">
                                    <i class="icon icon-arrow-right"></i>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>
    </div>
</div>
<!-- /Section Product -->
