@page
@model CrystalByRiya.Pages.myaccountModel
@{
}
@section Metatags {
    <title>Crystal By Riya | My Account</title>
    <meta name="keywords" content="Healing stones,Crystals and Gemstones,Healing crystals,Natural stones,Authentic crystals,Original crystals,Crystal jewellery,Sterling Silver Jewellery,Silver jewellery crystals,Silver jewellery" />
    <link rel="canonical" href="@Model.Currenturl" />
    <meta property="og:title" content="Crystal By Riya | My Account" />
    <meta property="og:url" content="@Model.Currenturl" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://djelgxoby50a9.cloudfront.net/logo/logo.png" />
    <meta property="og:site_name" content="https://www.crystalsbyriya.com" />
    <meta property="og:description" content="Shop authentic healing crystals from Crystals by Riya, India’s top crystal store. Discover exquisite jewelry, décor, and raw stones that bring balance to your health and wealth." />


    <meta name="twitter:card" content="summary">
    <meta name="twitter:site" content="https://www.crystalsbyriya.com">
    <meta name="twitter:title" content="Crystal By Riya | My Account">
    <meta name="twitter:description" content="Placing our customers at the core of everything we do, understanding their needs, and exceeding their expectations.">
    <meta name="twitter:creator" content="Crystals by Riya">
    <meta name="twitter:image" content="https://djelgxoby50a9.cloudfront.net/logo/logo.png">
    <meta name="twitter:domain" content="https://www.crystalsbyriya.com" />
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<main class="main-content">
    <!--== Start Page Title Area ==-->
    <div class="page-title-area page-title-area2">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="page-title-content content-style-2">
                        <div class="bread-crumbs">
                            <a href="/index">Home<span class="breadcrumb-sep">&gt;</span></a>
                            <a href="javascript:void(0)">Login/Register</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!--== End Page Title Area ==-->
    <!--== Start Contact Area ==-->
    <div class="account-login-area">
        <div class="container">
            <div class="row">
                <div class="col-lg-7 m-auto">
                    <div class="login-top">
                        <nav class="login-form-nav">
                            <div class="nav nav-tabs" id="nav-tab" role="tablist">
                                <button class="nav-link active" id="nav-home-tab" data-bs-toggle="tab" data-bs-target="#nav-home" type="button" role="tab" aria-controls="nav-home" aria-selected="true">
                                    <i class="lastudioicon-user-1"></i>Login
                                </button>
                                <button class="nav-link nav-register" id="nav-profile-tab" data-bs-toggle="tab" data-bs-target="#nav-profile" type="button" role="tab" aria-controls="nav-profile" aria-selected="false">
                                    <i class="lastudioicon-user-2"></i>Register
                                </button>
                            </div>
                        </nav>
                    </div>
                    <div class="login-bottom">
                        <div class="login-form-content tab-content" id="nav-tabContent">
                            <div class="tab-pane fade show active" id="nav-home" role="tabpanel" aria-labelledby="nav-home-tab">
                                <div class="login-form">
                                    <form class="login-form-wrapper" id="login-form" asp-page-handler="Login" method="post">
                                        <div class="row">
                                            <div class="col-lg-12">
                                                <div class="row">
                                                    <div class="col-md-12">
                                                        <div class="form-group">
                                                            <label for="UserName" class="form-label">Email address *</label>
                                                            <input type="email" class="form-control" id="UserName" asp-for="register.Email" />
                                                        </div>
                                                    </div>
                                                    <div class="col-md-12">
                                                        <div class="form-group mb-0">
                                                            <label for="password" class="form-label mt-15">Password *</label>
                                                            <input type="password" class="form-control" id="password" asp-for="register.Password" />
                                                        </div>
                                                    </div>  <input type="hidden" name="redirectUrl" value="@HttpContext.Request.Query["redirectUrl"]" />
                                                    <div class="col-md-12">
                                                        <div class="form-group mb-0 form-group-info">
                                                            <!-- Pass the returnUrl as a hidden input -->
                                                            <input type="hidden" name="returnUrl" value="/Index" />

                                                            <button class="btn btn-theme btn-black" type="submit">Log in</button>
                                                            <a class="btn-forgot" href="/ForgetPassword">Lost your password?</a>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="nav-profile" role="tabpanel" aria-labelledby="nav-profile-tab">
                                <div class="login-form">
                                    <form class="login-form-wrapper" id="register-form" method="post">
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="form-group">
                                                    <label for="fullName" class="form-label">Full Name</label>
                                                    <input type="text" class="form-control" id="fullName" required asp-for="register.Name" />
                                                </div>
                                            </div>
                                            <div class="col-md-12">
                                                <div class="form-group">
                                                    <label for="phone" class="form-label">Phone Number</label>
                                                    <input type="number" class="form-control" name="phone" id="phone" required asp-for="register.PhoneNumber" />
                                                    <span class="text-danger" id="existphone" style="display: none;">Phone number already exists.</span>
                                                 


                                                </div>
                                            </div>
                                            <div class="col-md-12">
                                                <div class="form-group">
                                                    <label for="email" class="form-label mt-15">Email Address</label>
                                                    <input type="email" class="form-control" id="email" name="Email" required asp-for="register.Email" />
                                                    <span class="text-danger" id="existemail" style="display: none;">Email already exists.</span>

                                                </div>
                                            </div>
                                            <div class="col-md-12">
                                                <div class="form-group mb-0">
                                                    <label for="password" class="form-label mt-15">Password</label>
                                                    <input type="password" class="form-control" id="password" required asp-for="register.Password" />
                                                </div>
                                            </div>

                                            <div class="col-md-12">
                                                <div class="form-group">
                                                    <p>Your personal data will be used to support your experience throughout this website, to manage access to your account, and for other purposes described in our privacy policy.</p>
                                                </div>
                                                <div class="col-md-12">
                                                    <div class="form-group mb-0 form-group-info">
                                                        <button class="btn btn-theme btn-black" type="submit" id="registerbtn">Register</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!--== End Contact Area ==-->
</main>
<script src="https://djelgxoby50a9.cloudfront.net/assetsv2/js/MyAccountPage.js"></script>



