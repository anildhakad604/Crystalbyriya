@page
@model CrystalByRiya.Pages.myaccountModel
@{
}
@section Metatags {
    <title>My Account | Dr Astro Crystals</title>
    <meta name="description" content="Login or register to your Dr Astro Crystals account to manage orders, wishlist, and profile. Access your personalized crystal collection and spiritual journey." />
    <meta name="keywords" content="Login, Register, My Account, Dr Astro Crystals, crystal orders, wishlist, spiritual products" />
    <link rel="canonical" href="@Model.Currenturl" />
    <meta property="og:title" content="My Account | Dr Astro Crystals" />
    <meta property="og:url" content="@Model.Currenturl" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://djelgxoby50a9.cloudfront.net/logo/logo.png" />
    <meta property="og:site_name" content="https://www.drastrocrystals.com" />
    <meta property="og:description" content="Login or register to your Dr Astro Crystals account to manage orders, wishlist, and profile. Access your personalized crystal collection and spiritual journey." />
    <meta name="twitter:card" content="summary">
    <meta name="twitter:site" content="https://www.drastrocrystals.com">
    <meta name="twitter:title" content="My Account | Dr Astro Crystals">
    <meta name="twitter:description" content="Login or register to manage your Dr Astro Crystals account. Access your personalized crystal collection and spiritual journey.">
    <meta name="twitter:creator" content="Dr Astro Crystals">
    <meta name="twitter:image" content="https://djelgxoby50a9.cloudfront.net/logo/logo.png">
    <meta name="twitter:domain" content="https://www.drastrocrystals.com" />
}

@{
    var redirectUrl = Request.Query["redirectUrl"].ToString();
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger text-center">@TempData["ErrorMessage"]</div>
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success text-center">@TempData["SuccessMessage"]</div>
}

<!-- Page Title -->
<section class="s-page-title">
    <div class="bg-overlay" style="background-image: url(images/banner/pexels-dan-nelson-1667453-4973899.jpg);">
    </div>
    <div class="container">
        <div class="content">
            <h1 class="title-page">Login/Register</h1>
            <ul class="breadcrumbs-page">
                <li><a asp-page="/Index" class="h6 link">Home</a></li>
                <li class="d-flex"><i class="icon icon-caret-right"></i></li>
                <li>
                    <h6 class="current-page fw-normal">Login/Register</h6>
                </li>
            </ul>
        </div>
    </div>
</section>
<!-- /Page Title -->
<!-- Login -->
<section class="flat-spacing">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-8 col-lg-6">
                <div role="tabpanel">
                    <!-- Tab group -->
                    <div class="tab-list" id="myList" role="tablist">
                        <a class="tab-link active" data-bs-toggle="tab" href="#login" role="tab">Login</a>
                        <a class="tab-link" data-bs-toggle="tab" href="#register" role="tab">Register</a>
                    </div>

                    <!-- Tab panes -->
                    <div class="tab-content">
                        <div class="tab-pane fade show active" id="login" role="tabpanel">
                            <div class="form-wrapper">
                                <form method="post" asp-page-handler="Login" class="form-login">
                                    <input type="hidden" name="redirectUrl" value="@redirectUrl" />
                                    <div class="list-ver">
                                        <fieldset>
                                            <input asp-for="register.Email" type="email" placeholder="Enter your email address *"
                                                   required autocomplete="email">
                                        </fieldset>
                                        <fieldset class="password-wrapper mb-8">
                                            <input asp-for="register.Password" class="password-field" type="password"
                                                   placeholder="Password *" required autocomplete="current-password">
                                            <span class="toggle-pass icon-show-password"></span>
                                        </fieldset>
                                        <div class="check-bottom">
                                            <div class="checkbox-wrap">
                                                <input id="remember" type="checkbox" class="tf-check" name="RememberMe">
                                                <label for="remember" class="h6">Keep me signed in</label>
                                            </div>
                                            <h6>
                                                <a asp-page="/ForgetPassword" class="link">
                                                    Forgot your password?
                                                </a>
                                            </h6>
                                        </div>
                                    </div>

                                    <button type="submit" class="tf-btn animate-btn w-100">
                                        Login
                                    </button>

                                    
                                </form>
                            </div>
                        </div>
                        <div class="tab-pane fade" id="register" role="tabpanel">
                            <div class="form-wrapper">
                                <form method="post" class="form-login">
                                    <div class="list-ver">
                                        <fieldset>
                                            <input asp-for="register.Name" type="text" placeholder="Enter your full name *"
                                                   required autocomplete="name" maxlength="100">
                                        </fieldset>
                                        <fieldset>
                                            <input asp-for="register.Email" id="register-email-visible" type="email" placeholder="Enter your email address *"
                                                   required autocomplete="email" maxlength="100">
                                            <input type="hidden" name="Email" id="register-email-hidden" />
                                        </fieldset>
                                        <fieldset>
                                            <input asp-for="register.PhoneNumber" id="register-phone-visible" type="tel" placeholder="Enter your phone number *"
                                                   required pattern="[0-9]{10}" maxlength="15">
                                            <input type="hidden" name="phone" id="register-phone-hidden" />
                                        </fieldset>
                                        <fieldset class="password-wrapper">
                                            <input asp-for="register.Password" class="password-field" type="password"
                                                   placeholder="Password *" required autocomplete="new-password" minlength="8">
                                            <span class="toggle-pass icon-show-password"></span>
                                        </fieldset>
                                        <div class="checkbox-wrap">
                                            <input id="terms" type="checkbox" class="tf-check" required>
                                            <label for="terms" class="h6">
                                                I agree to the <a asp-page="/termandconditions" class="link">Terms &amp; Conditions</a>
                                                and <a asp-page="/Privacy" class="link">Privacy Policy</a>
                                            </label>
                                        </div>
                                    </div>
                                    <button type="submit" class="tf-btn animate-btn w-100">
                                        Register
                                    </button>

                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- /Login -->
<script>
    (function () {
        var emailVisible = document.getElementById("register-email-visible");
        var emailHidden = document.getElementById("register-email-hidden");
        var phoneVisible = document.getElementById("register-phone-visible");
        var phoneHidden = document.getElementById("register-phone-hidden");

        function syncRegisterFields() {
            if (emailHidden && emailVisible) {
                emailHidden.value = emailVisible.value;
            }

            if (phoneHidden && phoneVisible) {
                phoneHidden.value = phoneVisible.value;
            }
        }

        if (emailVisible) {
            emailVisible.addEventListener("input", syncRegisterFields);
        }

        if (phoneVisible) {
            phoneVisible.addEventListener("input", syncRegisterFields);
        }

        syncRegisterFields();
    })();
</script>
