@page
@model CrystalByRiya.Pages.blogModel
@{
    var pageTitle = "Blogs | Dr Astro Crystals";
    var pageDescription = "Read our latest blogs on healing crystals, gemstones, astrology, and spiritual wellness.";
}
@section Metatags {
    <title>@pageTitle</title>
    <meta name="description" content="@pageDescription" />
    <meta name="keywords" content="Healing stones,Crystals and Gemstones,Healing crystals,Natural stones,Authentic crystals,Original crystals,Crystal jewellery,Sterling Silver Jewellery,Silver jewellery crystals,Silver jewellery" />
    <link rel="canonical" href="@Model.Currenturl" />
    <meta property="og:title" content="@pageTitle" />
    <meta property="og:description" content="@pageDescription" />
    <meta property="og:url" content="@Model.Currenturl" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="https://djelgxoby50a9.cloudfront.net/logo/logo.png" />
    <meta property="og:site_name" content="https://www.drastrocrystals.com" />
    <meta name="twitter:card" content="summary">
    <meta name="twitter:site" content="https://www.drastrocrystals.com">
    <meta name="twitter:title" content="@pageTitle">
    <meta name="twitter:description" content="@pageDescription">
    <meta name="twitter:creator" content="Dr Astro Crystals">
    <meta name="twitter:image" content="https://djelgxoby50a9.cloudfront.net/logo/logo.png">
    <meta name="twitter:domain" content="https://www.drastrocrystals.com" />
}

<!-- Page Title -->
<section class="s-page-title">
    <div class="bg-overlay" style="background-image: url(images/banner/1.png);">
    <div class="container">
        <div class="content">
            <h1 class="title-page">Blog</h1>
            <ul class="breadcrumbs-page">
                <li><a asp-page="/Index" class="h6 link">Home</a></li>
                <li class="d-flex"><i class="icon icon-caret-right"></i></li>
                <li>
                    <h6 class="current-page fw-normal">Blog Grid</h6>
                </li>
            </ul>
        </div>
    </div>
</section>
<!-- Blog Grid -->
<div class="flat-spacing">
    <div class="container">
        @if (Model.Blogs != null && Model.Blogs.Any())
        {
            <div class="tf-grid-layout sm-col-2 lg-col-3">
                @foreach (var item in Model.Blogs)
                {
                    var blogRouteUrl = item.CustomUrl ?? item.BlogTitle;
                    var blogDetailUrl = Url.Page("/blogdetail", new { blogid = item.Blogid, url = blogRouteUrl }) ?? "/blog";
                    var blogImage = string.IsNullOrWhiteSpace(item.ThumbnailImage) ? item.Image : item.ThumbnailImage;
                    var blogAlt = string.IsNullOrWhiteSpace(item.Alttext) ? item.BlogTitle : item.Alttext;
                    var blogExcerpt = item.ShortDescription;

                    if (string.IsNullOrWhiteSpace(blogExcerpt))
                    {
                        blogExcerpt = item.Blogdescription;
                    }

                    if (!string.IsNullOrWhiteSpace(blogExcerpt))
                    {
                        blogExcerpt = System.Text.RegularExpressions.Regex.Replace(blogExcerpt, "<.*?>", string.Empty).Trim();
                        if (blogExcerpt.Length > 100)
                        {
                            blogExcerpt = $"{blogExcerpt.Substring(0, 100)}...";
                        }
                    }

                    <div class="article-blog hover-img4">
                        <div class="blog-image">
                            <a href="@blogDetailUrl" class="entry_image img-style4">
                                <img src="/images/blog/@blogImage"
                                     data-src="/images/blog/@blogImage"
                                     alt="@blogAlt"
                                     class="lazyload"
                                    >
                            </a>
                            <div class="entry_tag">
                                <span class="name-tag h6">@(item.PublishedDate.ToString("MMMM dd, yyyy"))</span>
                            </div>
                        </div>
                        <div class="blog-content">
                            <a href="@blogDetailUrl" class="entry_name link h4">
                                @item.BlogTitle
                            </a>
                            <p class="h6 mt-2">@(string.IsNullOrWhiteSpace(blogExcerpt) ? "Explore our latest article on crystals and spiritual wellness." : blogExcerpt)</p>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <div class="tf-pagination-wrap d-flex justify-content-center mt-40">
                    <ul class="tf-pagination-list">
                        @if (Model.CurrentPage > 1)
                        {
                            <li>
                                <a asp-page="/blog" asp-route-page="@(Model.CurrentPage - 1)" class="pagination-link">
                                    <i class="icon icon-arrow-left"></i>
                                </a>
                            </li>
                        }
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li>
                                <a asp-page="/blog" asp-route-page="@i" class="pagination-link @(i == Model.CurrentPage ? "active" : "")">@i</a>
                            </li>
                        }
                        @if (Model.CurrentPage < Model.TotalPages)
                        {
                            <li>
                                <a asp-page="/blog" asp-route-page="@(Model.CurrentPage + 1)" class="pagination-link">
                                    <i class="icon icon-arrow-right"></i>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            }
        }
        else
        {
            <div class="text-center py-5">
                <i class="icon icon-article fs-1 mb-3 text-secondary"></i>
                <h3>No blogs found</h3>
                <p class="mb-4">Check back soon for our latest articles on crystals and spirituality.</p>
                <a asp-page="/Index" class="tf-btn animate-btn">Back to Home</a>
            </div>
        }
    </div>
</div>
<!-- /Blog Grid -->
