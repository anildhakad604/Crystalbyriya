@page "{name?}"
@model CrystalByRiya.Pages.SearchResultModel

@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    var searchTerm = Model.SearchTerm;
    var resultCount = Model.SelectedProduct?.Count ?? 0;
}

@section Metatags {
    <title>Dr Astro Crystals | Search Results</title>
    <meta name="keywords" content="Healing stones,Crystals and Gemstones,Healing crystals,Natural stones,Authentic crystals,Original crystals,Crystal jewellery,Sterling Silver Jewellery,Silver jewellery crystals,Silver jewellery" />
    <link rel="canonical" href="@Model.Currenturl" />
    <meta property="og:title" content="Dr Astro Crystals | Search Results" />
    <meta property="og:url" content="@Model.Currenturl" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="https://www.drastrocrystals.com" />
    <meta name="twitter:card" content="summary">
    <meta name="twitter:site" content="https://www.drastrocrystals.com">
    <meta name="twitter:title" content="Dr Astro Crystals | Search Results">
    <meta name="twitter:description" content="Placing our customers at the core of everything we do, understanding their needs, and exceeding their expectations.">
    <meta name="twitter:creator" content="Dr Astro Crystals">
    <meta name="twitter:domain" content="https://www.drastrocrystals.com" />
}






<main class="main-content">
    <!--== Start Page Title Area ==-->
    <div class="page-title-area page-title-area2">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="page-title-content content-style-2">
                        <div class="bread-crumbs"><a asp-page="/Index">Home<span class="breadcrumb-sep">&gt;</span></a><a href="javascript:void(0)">Search Results</a></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!--== End Page Title Area ==-->
    <!--== Start Product List Area ==-->
    <section class="product-list-area pt-3 pt-md-5 area-padding">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="inner-left-padding">
                        <div class="shop-toolbar-wrap">
                        
                            <div class="shop-toolbar-right">
                                <div class="product-showing-status">
                                    <p class="count-result">Showing @resultCount result@(resultCount == 1 ? string.Empty : "s")</p>
                                </div>
                            </div>
                        </div>

                        <div class="product-list-item-parent">
                            <div class="row" id="product-container">
                                @if (Model.SelectedProduct != null && Model.SelectedProduct.Any())
                                {
                                    @foreach (var product in Model.SelectedProduct)
                                    {
                                        var productRouteName = string.IsNullOrWhiteSpace(product.ParentUrl) ? product.ProductName : product.ParentUrl;
                                        <div class="col-6 col-md-4 col-lg-3">
                                            <!-- Start Product Item -->
                                            <div class="product-item">
                                                <div class="product-thumb">
                                                    <a asp-page="/detail" asp-route-skucode="@product.SkuCode" asp-route-productname="@productRouteName">
                                                        <img src="/images/products/@product.Thumbnail" alt="@(string.IsNullOrWhiteSpace(product.AltText) ? product.ProductName : product.AltText)" class="lazyload">
                                                        <span class="bg-thumb" data-bg-img="/images/products/@product.Thumbnail" style="background-image: url(/images/products/@product.Thumbnail);"></span>
                                                        <span class="thumb-overlay"></span>
                                                    </a>
                                                    <div class="product-action">
                                                        <a href="#quickView" data-bs-toggle="modal" class="action-quick-view ht-tooltip quview" id="@product.SkuCode" data-tippy-content="Quick View">
                                                            <i class="lastudioicon-eye"></i>
                                                        </a>

                                                        <!-- Add to Wishlist Form -->
                                                        <form method="post" asp-page-handler="AddToWishlist" style="display:inline;">
                                                            <input type="hidden" name="SkuCode" value="@product.SkuCode" />
                                                            <input type="hidden" name="ProductName" value="@product.ProductName" />
                                                            <input type="hidden" name="buynow" value="false" />
                                                            <button type="submit" class="action-wishlist ht-tooltip" data-tippy-content="Add to wishlist">
                                                                <i class="lastudioicon-heart-2"></i>
                                                            </button>
                                                        </form>

                                                        <!-- Add to Cart Form -->
                                                        <form method="post" asp-page-handler="AddToCart" style="display:inline;">
                                                            <input type="hidden" name="SkuCode" value="@product.SkuCode" />
                                                            <input type="hidden" name="ProductName" value="@product.ProductName" />
                                                            <input type="hidden" name="Qty" value="1" />
                                                            <input type="hidden" name="Price" value="@product.Price" />
                                                            <button type="submit" class="action-cart ht-tooltip" data-tippy-content="Add to cart">
                                                                <i class="lastudioicon-bag-3"></i>
                                                            </button>
                                                        </form>
                                                    </div>
                                                </div>
                                                <div class="product-footer position-relative">
                                                    <div class="product-info d-block">
                                                        <div class="content-inner text-center">
                                                            <h4 class="title">
                                                                <a asp-page="/detail" asp-route-skucode="@product.SkuCode" asp-route-productname="@productRouteName">
                                                                    @product.ProductName
                                                                </a>
                                                            </h4>
                                                            <div class="prices">
                                                                <span class="price">₹@product.Price</span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="product-action-button-parent">
                                                        <form method="post" asp-page-handler="AddToCart">
                                                            <input type="hidden" name="SkuCode" value="@product.SkuCode" />
                                                            <input type="hidden" name="ProductName" value="@product.ProductName" />
                                                            <input type="hidden" name="Qty" value="1" />
                                                            <input type="hidden" name="Price" value="@product.Price" />
                                                            <button type="submit" class="btn product-action-button">
                                                                <i class="lastudioicon-bag-3 me-1"></i> ADD TO CART
                                                            </button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                            <!-- End Product Item -->
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="col-12">
                                        <div class="alert alert-info text-center">
                                            <h4>No products found</h4>
                                            <p>@(string.IsNullOrWhiteSpace(searchTerm) ? "Try adjusting your search terms or browse our categories." : $"No products matched \"{searchTerm}\". Try adjusting your search terms or browse our categories.")</p>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!--== End Product List Area ==-->
    <aside class="product-quick-view-modal">
        <div class="product-quick-view-inner">
            <div class="product-quick-view-content">
                <button type="button" class="btn-close">
                    <span class="close-icon"><i class="lastudioicon-e-remove"></i></span>
                </button>
                <div class="row row-gutter-0">
                    <div class="col-lg-6 col-md-6 col-12">
                        <div class="thumb">
                            <div class="swiper-container quick-view-slider-container">
                                <div class="swiper-wrapper">
                                    <div class="swiper-slide">
                                        <img src="https://djelgxoby50a9.cloudfront.net/assetsv2/img/by-category/quick-view/1.jpg" alt="">
                                    </div>
                                    <div class="swiper-slide">
                                        <img src="https://djelgxoby50a9.cloudfront.net/assetsv2/img/by-category/quick-view/2.jpg" alt="">
                                    </div>
                                </div>
                                <!-- Add Arrows -->
                                <div class="swiper-button-next"></div>
                                <div class="swiper-button-prev"></div>
                                <!-- Add Pagination -->
                                <div class="swiper-pagination"></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6 col-md-6 col-12">
                        <div class="single-product-info">
                            <h4 class="title">Title</h4>
                            <div class="product-rating">
                                <div class="review">
                                    <p><span></span>99 in stock</p>
                                </div>
                            </div>
                            <div class="prices">
                                <span class="price">&#8377; 111100</span>
                            </div>
                            <p class="product-desc mb-3">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Fringilla quis ipsum enim viverra. Enim in morbi tincidunt ante luctus tincidunt integer. Sed adipiscing vehicula.</p>
                            <div class="sizes mb-4">
                                <h6 class="title" id="title">Sizes</h6>
                                <button type="button" class="btn btn-sizes">50mm</button>
                                <button type="button" class="btn btn-sizes">4mm</button>
                                <button type="button" class="btn btn-sizes">6mm</button>
                                <button type="button" class="btn btn-sizes">8mm</button>
                            </div>
                            <div class="material mb-4">
                                <h6 class="title" id="title">Material</h6>
                                <button type="button" class="btn btn-sizes">Gold</button>
                                <button type="button" class="btn btn-sizes">Silver</button>
                                <button type="button" class="btn btn-sizes">Bronze</button>
                            </div>

                            <div class="quick-product-action">
                                <div class="action-top">
                                    <div class="pro-qty-area">
                                        <div class="pro-qty">
                                            <input type="text" id="quantity1" title="Quantity" value="1" name="Qty" min="1" max="10">
                                            <a class="inc qty-btn">+</a><a class="dec qty-btn">-</a>
                                        </div>
                                    </div>
                                    <a class="btn-theme btn-black" onclick="HandleAddToCart3()">Add to cart</a>
                                </div>
                                <form id="addtocartForms" method="post" asp-page-handler="AddToCart" style="display:none;">
                                    @Html.AntiForgeryToken() <!-- Protect against CSRF attacks -->
                                    <input type="hidden" id="Skucode" name="SkuCode" />
                                    <input type="hidden" id="Productname" name="ProductName" />
                                    <input type="hidden" id="totalPrice" name="Price" />
                                    <input type="hidden" id="selectedSize" name="Size" />
                                    <input type="hidden" id="selectedMaterial" name="MaterialName" />
                                    <input type="hidden" id="quantity" name="Qty" />
                                </form>
                                <div class="action-bottom">
                                    <a class="btn-wishlist"><i class="labtn-icon labtn-icon-wishlist" onclick="HandleAddToWishlist3()"></i>Add to wishlist</a>
                                </div>
                                <form id="wishlistForms" method="post" asp-page-handler="AddToWishlist" style="display:none;">
                                    @Html.AntiForgeryToken() <!-- Protect against CSRF attacks -->
                                    <input type="hidden" id="Skucode1" name="SkuCode" />
                                    <input type="hidden" id="Productname1" name="ProductName" />
                                    <input type="hidden" id="Buynow" name="buynow" value="false" />
                                </form>
                            </div>
                            <div class="product-ratting">
                                <div class="product-sku">
                                    SKU: <span>N/A</span>
                                </div>
                            </div>

                            <div class="widget">
                                <h3 class="title">Tags:</h3>
                                <div class="widget-tags">
                                    <ul>
                                        <li><a href="#">lorem,</a></li>
                                        <li><a href="#">lorem,</a></li>
                                    </ul>
                                </div>
                            </div>
                           
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="canvas-overlay"></div>
    </aside>
</main>

@section Scripts {
    <script>

    </script>
    <script src="https://djelgxoby50a9.cloudfront.net/assetsv2/js/ProductQuickView.js">

    </script>
}
