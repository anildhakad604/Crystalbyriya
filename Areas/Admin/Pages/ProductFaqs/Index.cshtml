@page
@model CrystalByRiya.Areas.Admin.Pages.ProductFaqs.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create"class="btn btn-danger">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ProductFaq[0].ProductSku)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProductFaq[0].Question)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ProductFaq[0].Answer)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.ProductFaq) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.ProductSku)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Question)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Answer)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
