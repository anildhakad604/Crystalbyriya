@page
@model CrystalByRiya.Areas.Admin.Pages.Products.IndexModel

@{
    ViewData["Title"] = "Product List";
}

<h2 class="text-center display-4 font-weight-bold mt-4 mb-4" style="color:#2c3e50; letter-spacing: 2px;">Product List</h2>

<!-- Search Bar with Autocomplete -->
<form method="get" class="mb-4 position-relative">
    <div class="input-group">
        <input type="text" name="SearchTerm" id="searchInput" placeholder="Search products by name or SKU" class="form-control" autocomplete="off" />
        <button type="submit" class="btn btn-primary">
            <i class="fa fa-search"></i> Search
        </button>
    </div>
    <!-- Autocomplete suggestions dropdown -->
    <div id="suggestionsDropdown" class="list-group position-absolute w-100" style="z-index: 1000;"></div>
</form>

<!-- Create New Product Button -->
<p class="text-center">
    <a asp-page="Create" class="btn btn-lg btn-danger px-5 py-3" style="font-size: 18px; letter-spacing: 1px;">
        <i class="fa fa-plus-circle"></i> Create New
    </a>
</p>

<!-- Table for Products -->
<table class="table table-striped table-hover">
    <thead class="text-center" style="background-color:black; color:#fff;">
        <tr>
            <th>@Html.DisplayNameFor(model => model.Product[0].Thumbnail)</th>
            <th>@Html.DisplayNameFor(model => model.Product[0].SkuCode)</th>
            <th>@Html.DisplayNameFor(model => model.Product[0].ProductName)</th>
            <th>@Html.DisplayNameFor(model => model.Product[0].Qty)</th>
            <th>@Html.DisplayNameFor(model => model.Product[0].Price)</th>
            <th>@Html.DisplayNameFor(model => model.Product[0].AddedOn)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Product.Any())
        {
            @foreach (var item in Model.Product)
            {
                <tr class="text-center align-middle">
                    <td>
                        @if (!string.IsNullOrEmpty(item.Thumbnail))
                        {
                            <img src=" https://djelgxoby50a9.cloudfront.net/Images/@(item.Thumbnail)" width="100" height="100" class="lazyload" />
                        }
                        else
                        {
                            <span>No Image</span>
                        }
                    </td>
                    <td>@Html.DisplayFor(modelItem => item.SkuCode)</td>
                    <td>@Html.DisplayFor(modelItem => item.ProductName)</td>
                    <td>@Html.DisplayFor(modelItem => item.Qty)</td>
                    <td>@Html.DisplayFor(modelItem => item.Price)</td>
                    <td>@item.AddedOn.ToShortDateString()</td>
                    <td>
                        <div class="btn-group">
                            <a asp-page="./Edit" asp-route-id="@item.ID" class="btn btn-secondary" style="margin-right:5px;">
                                <i class="fa fa-edit"></i> Edit
                            </a>
                            <a asp-page="./Details" asp-route-id="@item.ID" class="btn btn-success">
                                <i class="fa fa-info-circle"></i> Info
                            </a>
                            <a asp-page="./Delete" asp-route-id="@item.ID" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this product?');">
                                <i class="fa fa-trash"></i> Delete
                            </a>
                        </div>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center">No products found.</td>
            </tr>
        }
    </tbody>
</table>

<!-- Pagination Controls -->
<div class="text-center mt-4">
    @if (Model.CurrentPage > 1)
    {
        <a asp-page="./Index" asp-route-currentPage="@(Model.CurrentPage - 1)" asp-route-SearchTerm="@Model.SearchTerm" class="btn btn-outline-secondary">Previous</a>
    }

    @for (int i = 1; i <= Model.TotalPages; i++)
    {
        if (i == Model.CurrentPage)
        {
            <span class="btn btn-primary">@i</span>
        }
        else
        {
            <a asp-page="./Index" asp-route-currentPage="@i" asp-route-SearchTerm="@Model.SearchTerm" class="btn btn-outline-secondary">@i</a>
        }
    }

    @if (Model.CurrentPage < Model.TotalPages)
    {
        <a asp-page="./Index" asp-route-currentPage="@(Model.CurrentPage + 1)" asp-route-SearchTerm="@Model.SearchTerm" class="btn btn-outline-secondary">Next</a>
    }
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/js/all.min.js"></script>

    <script>
        document.getElementById("searchInput").addEventListener("input", async function () {
            const searchTerm = this.value.trim();
            const suggestionsDropdown = document.getElementById("suggestionsDropdown");
            suggestionsDropdown.innerHTML = ""; // Clear previous suggestions

            if (searchTerm.length > 0) {
                try {
                    // Fetch suggestions from the new API endpoint
                    const response = await fetch(`/api/ProductsApi/suggestions?searchTerm=${encodeURIComponent(searchTerm)}`);
                    const suggestions = await response.json();

                    if (suggestions.length > 0) {
                        // Populate suggestions dropdown
                        suggestions.forEach(suggestion => {
                            const item = document.createElement("a");
                            item.className = "list-group-item list-group-item-action";
                            item.href = `?SearchTerm=${suggestion.productName}`; // Access using lowercase as returned from API
                            item.textContent = `${suggestion.productName} (${suggestion.skuCode})`; // Access properties with correct names
                            item.addEventListener("click", function (e) {
                                e.preventDefault();
                                document.getElementById("searchInput").value = suggestion.productName;
                                suggestionsDropdown.innerHTML = ""; // Clear suggestions
                            });
                            suggestionsDropdown.appendChild(item);
                        });
                    }
                } catch (error) {
                    console.error("Error fetching suggestions:", error);
                }
            }
        });

        // Hide dropdown when clicking outside
        document.addEventListener("click", function (e) {
            const dropdown = document.getElementById("suggestionsDropdown");
            if (!dropdown.contains(e.target) && e.target.id !== "searchInput") {
                dropdown.innerHTML = "";
            }
        });
    </script>

}
