@page
@model CrystalByRiya.Areas.Admin.Pages.Comments.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.CommentReply[0].BlogId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CommentReply[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CommentReply[0].Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CommentReply[0].Comment)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CommentReply[0].IsApproved)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CommentReply[0].Date)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.CommentReply) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.BlogId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Comment)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IsApproved)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Date)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
