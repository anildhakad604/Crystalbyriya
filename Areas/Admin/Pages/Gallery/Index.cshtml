@page
@model CrystalByRiya.Areas.Admin.Pages.Gallery.IndexModel

@{
    ViewData["Title"] = "Image Gallery";
}

<h2 class="text-center display-4 font-weight-bold mt-4 mb-4" style="color:#2c3e50; letter-spacing: 2px;">Image Gallery</h2>

<!-- Search Bar with Autocomplete -->
<form method="get" class="mb-4 position-relative">
    <div class="input-group">
        <input type="text" name="SearchTerm" id="searchInput" placeholder="Search images by Product ID or Type" class="form-control" autocomplete="off" />
        <button type="submit" class="btn btn-primary">
            <i class="fa fa-search"></i> Search
        </button>
    </div>
    <!-- Autocomplete suggestions dropdown -->
    <div id="suggestionsDropdown" class="list-group position-absolute w-100" style="z-index: 1000;"></div>
</form>

<!-- Create New Image Button -->
<p class="text-center">
    <a asp-page="Create" class="btn btn-lg btn-danger px-5 py-3" style="font-size: 18px; letter-spacing: 1px;">
        <i class="fa fa-plus-circle"></i> Create New
    </a>
</p>

<!-- Card Layout for Images -->
<div class="container">
    <div class="row">
        @if (Model.ImageGallery.Any())
        {
            @foreach (var item in Model.ImageGallery)
            {
                <div class="col-md-4 col-sm-6 mb-4">
                    <div class="card shadow-sm border-0 h-100" style="transition: all 0.3s ease;">
                        <div class="card-body text-center d-flex flex-column justify-content-between">
                            <h5 class="card-title font-weight-bold">@item.Productid</h5>
                            @if (!string.IsNullOrEmpty(item.Url))
                            {
                                <img src="https://djelgxoby50a9.cloudfront.net/Images/@(item.Url)" class="" lazyload"" style="max-height: 200px; object-fit: cover; transition: transform 0.3s ease;" alt="Image" />
                            }
                            else
                            {
                                <div class="no-image-placeholder" style="height: 200px; display: flex; justify-content: center; align-items: center; background-color: #f2f2f2;">
                                    <span>No Image</span>
                                </div>
                            }
                            <p class="card-text mt-3">Type: <strong>@item.Type</strong></p>

                            <!-- Action Buttons -->
                            <div class="d-flex justify-content-around mt-4">
                                <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-primary btn-sm">
                                    <i class="fa fa-edit"></i> Edit
                                </a>
                                <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">
                                    <i class="fa fa-info-circle"></i> Details
                                </a>
                                <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this image?');">
                                    <i class="fa fa-trash"></i> Delete
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center w-100">No images found.</div>
        }
    </div>
</div>

<!-- Pagination Controls -->
<div class="text-center mt-4">
    @if (Model.CurrentPage > 1)
    {
        <a asp-page="./Index" asp-route-currentPage="@(Model.CurrentPage - 1)" asp-route-SearchTerm="@Model.SearchTerm" class="btn btn-outline-secondary">Previous</a>
    }

    @for (int i = 1; i <= Model.TotalPages; i++)
    {
        if (i == Model.CurrentPage)
        {
            <span class="btn btn-primary">@i</span>
        }
        else
        {
            <a asp-page="./Index" asp-route-currentPage="@i" asp-route-SearchTerm="@Model.SearchTerm" class="btn btn-outline-secondary">@i</a>
        }
    }

    @if (Model.CurrentPage < Model.TotalPages)
    {
        <a asp-page="./Index" asp-route-currentPage="@(Model.CurrentPage + 1)" asp-route-SearchTerm="@Model.SearchTerm" class="btn btn-outline-secondary">Next</a>
    }
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/js/all.min.js"></script>

    <script>
        document.getElementById("searchInput").addEventListener("input", async function () {
            const searchTerm = this.value.trim();
            const suggestionsDropdown = document.getElementById("suggestionsDropdown");
            suggestionsDropdown.innerHTML = "";

            if (searchTerm.length > 0) {
                try {
                    const response = await fetch(`/api/ImageGalleryApi/suggestions?searchTerm=${encodeURIComponent(searchTerm)}`);
                    const suggestions = await response.json();

                    if (suggestions.length > 0) {
                        suggestions.forEach(suggestion => {
                            const item = document.createElement("a");
                            item.className = "list-group-item list-group-item-action";
                            item.href = `?SearchTerm=${suggestion.productid}`;
                            item.textContent = `${suggestion.productid} (${suggestion.type})`;
                            item.addEventListener("click", function (e) {
                                e.preventDefault();
                                document.getElementById("searchInput").value = suggestion.productid;
                                suggestionsDropdown.innerHTML = "";
                            });
                            suggestionsDropdown.appendChild(item);
                        });
                    }
                } catch (error) {
                    console.error("Error fetching suggestions:", error);
                }
            }
        });

        document.addEventListener("click", function (e) {
            const dropdown = document.getElementById("suggestionsDropdown");
            if (!dropdown.contains(e.target) && e.target.id !== "searchInput") {
                dropdown.innerHTML = "";
            }
        });
    </script>
    <style>
        .card:hover {
            transform: translateY(-10px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
        }

        .img-fluid:hover {
            transform: scale(1.1);
        }
    </style>
}
