@page
@model CrystalByRiya.Areas.Admin.Pages.ReviewGalleries.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create" class="btn btn-danger">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ReviewGallery[0].ImageName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ReviewGallery[0].Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ReviewGallery[0].ProductId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ReviewGallery[0].Approved)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.ReviewGallery) {
        <tr>
            <td>
                    <img src="https://www.crystalsbyriya.com/images/@item.ImageName" height="50" width="50" class="lazyload" />
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ProductId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Approved)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
