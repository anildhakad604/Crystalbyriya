            </div>
            <div class="form-group">
                <label asp-for="TblReviews.Emailid" class="control-label"></label>
                <input asp-for="TblReviews.Emailid" class="form-control" />
                <span asp-validation-for="TblReviews.Emailid" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TblReviews.Name" class="control-label"></label>
                <input asp-for="TblReviews.Name" class="form-control" />
                <span asp-validation-for="TblReviews.Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TblReviews.ReviewDate" class="control-label"></label>
                <input asp-for="TblReviews.ReviewDate" class="form-control" />
                <span asp-validation-for="TblReviews.ReviewDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
