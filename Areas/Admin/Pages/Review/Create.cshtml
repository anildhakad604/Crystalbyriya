@page
@model CrystalByRiya.Areas.Admin.Pages.Review.CreateModel

        @{
        ViewData["Title"] = "Create";
        }
        
        <h1>Create</h1>
        
    <h4>TblReviews</h4>
    <hr />
    <div class="row">
    <div class="col-md-4">
    <form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="TblReviews.Productid" class="control-label"></label>
                <input asp-for="TblReviews.Productid" class="form-control" />
                <span asp-validation-for="TblReviews.Productid" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TblReviews.Reviews" class="control-label"></label>
                <input asp-for="TblReviews.Reviews" class="form-control" />
                <span asp-validation-for="TblReviews.Reviews" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="TblReviews.IsApproved" /> @Html.DisplayNameFor(model => model.TblReviews.IsApproved)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="TblReviews.Rating" class="control-label"></label>
                <input asp-for="TblReviews.Rating" class="form-control" />
