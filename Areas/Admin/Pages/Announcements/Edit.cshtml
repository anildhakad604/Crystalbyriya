@page
@model CrystalByRiya.Areas.Admin.Pages.Announcements.EditModel
@{
    ViewData["Title"] = "Edit Announcement";
}

<h2>Edit Announcement</h2>

<form method="post">
    <div class="form-group">
        <label asp-for="Announcement.Id" class="control-label"></label>
        <input asp-for="Announcement.Id" class="form-control" />
        <span asp-validation-for="Announcement.Id" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Announcement.AnnouncementText" class="control-label"></label>
        <input asp-for="Announcement.AnnouncementText" class="form-control" />
        <span asp-validation-for="Announcement.AnnouncementText" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-page="Index" class="btn btn-secondary">Back to List</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}