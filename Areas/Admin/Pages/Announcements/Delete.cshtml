@page
@model CrystalByRiya.Areas.Admin.Pages.Announcements.DeleteModel
@{
    ViewData["Title"] = "Delete Announcement";
}

<h2>Delete Announcement</h2>

<h3>Are you sure you want to delete this announcement?</h3>

<div>
    <h4>Announcement</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            Id
        </dt>
        <dd class="col-sm-10">
            @Model.Announcement.Id
        </dd>
        <dt class="col-sm-2">
            Announcement Text
        </dt>
        <dd class="col-sm-10">
            @Model.Announcement.AnnouncementText
        </dd>
    </dl>

    <form method="post">
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-page="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>