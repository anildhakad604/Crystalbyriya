@page
@model CrystalByRiya.Areas.Admin.Pages.Subcategories.IndexModel

<h2>Subcategories</h2>

<p>
    <a asp-page="Create" class="btn btn-danger">Create New Subcategory</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Category Image</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Subcategories)
        {
                <tr>
                    <td>@item.CategoryId</td>
                    <td>@item.SubCategoryname</td>
                    <td>@item.Categoryimage</td>
                    <td>
                        <a asp-page="Edit" asp-route-id="@item.SubCategoryid" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-page="Details" asp-route-id="@item.SubCategoryid" class="btn btn-sm btn-info">Details</a>
                        <a asp-page="Delete" asp-route-id="@item.SubCategoryid" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
        }
    </tbody>
</table>
