@page
@model CrystalByRiya.Areas.Admin.Pages.Subcategories.DetailsModel

<h2>Subcategory Details</h2>

<div>
    <h4>Subcategory</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">ID</dt>
        <dd class="col-sm-10">@Model.Subcategory.SubCategoryid</dd>

        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Subcategory.SubCategoryname</dd>

        <dt class="col-sm-2">Category Image</dt>
        <dd class="col-sm-10">@Model.Subcategory.Categoryimage</dd>

        <dt class="col-sm-2">Category ID</dt>
        <dd class="col-sm-10">@Model.Subcategory.CategoryId</dd>

        <dt class="col-sm-2">Category Description</dt>
        <dd class="col-sm-10">@Model.Subcategory.CategoryDescription</dd>

        <dt class="col-sm-2">Thumbnail Image</dt>
        <dd class="col-sm-10">@Model.Subcategory.ThumbnailImage</dd>
    </dl>

    <a asp-page="Index" class="btn btn-secondary">Back to List</a>
</div>
