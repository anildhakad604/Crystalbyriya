@page
@model CrystalByRiya.Areas.Admin.Pages.Banners.IndexModel

@{
    ViewData["Title"] = "Banner List";
}

<!-- Centered Title -->
<h2 class="text-center display-4 font-weight-bold mt-4 mb-4" style="color:#2c3e50; letter-spacing: 2px;">Banner List</h2>

<!-- Centered Create New Button -->
<div class="text-center mb-4">
    <a asp-page="Create" class="btn btn-lg px-5 py-3" style="background: linear-gradient(90deg, #ff6b6b, #ee5253); color: white; font-size: 18px; letter-spacing: 1px; box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1); border-radius: 50px;">
        <i class="fa fa-plus-circle"></i> Create New
    </a>
</div>

<!-- Table for Banner List -->
<table class="table table-striped table-hover">
    <thead class="text-center" style="background-color:black; color:#fff;">
        <tr>
            <th>Mobile Image/Video</th>
            <th>Desktop Image/Video</th>
            <th>@Html.DisplayNameFor(model => model.Banners[0].TargetUrl)</th>
            <th>@Html.DisplayNameFor(model => model.Banners[0].AltText)</th>
            <th>@Html.DisplayNameFor(model => model.Banners[0].Type)</th>
            <th>@Html.DisplayNameFor(model => model.Banners[0].Text)</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Banners)
        {
            if (item.Type == "Image")
            {
                <tr class="text-center align-middle">
                    <td><img src="~/images/slider/@item.MobileImageName" style="width:50%; height:50%;" /></td>
                    <td><img src="~/images/slider/@item.DesktopImageName" style="width:50%; height:50%;" /></td>
                    <td>@Html.DisplayFor(modelItem => item.TargetUrl)</td>
                    <td>@Html.DisplayFor(modelItem => item.AltText)</td>
                    <td>@Html.DisplayFor(modelItem => item.Type)</td>
                    <td>@Html.DisplayFor(modelItem => item.Text)</td>
                    <td>
                        <div class="btn-group">
                            <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-gradient-primary">
                                <i class="fa fa-edit"></i> Edit
                            </a>
                            <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-gradient-info">
                                <i class="fa fa-info-circle"></i> Details
                            </a>
                            <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-gradient-danger">
                                <i class="fa fa-trash"></i> Delete
                            </a>
                        </div>
                    </td>
                </tr>
            }
            else
            {
                <tr class="text-center align-middle">
                    <td><video src="@item.MobileImageName" style="width:50%; height:50%;"></video></td>
                    <td><video src="@item.DesktopImageName" style="width:50%; height:50%;"></video></td>
                    <td>@Html.DisplayFor(modelItem => item.TargetUrl)</td>
                    <td>@Html.DisplayFor(modelItem => item.AltText)</td>
                    <td>@Html.DisplayFor(modelItem => item.Type)</td>
                    <td>@Html.DisplayFor(modelItem => item.Text)</td>
                    <td>
                        <div class="btn-group">
                            <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-gradient-primary">
                                <i class="fa fa-edit"></i> Edit
                            </a>
                            <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-gradient-info">
                                <i class="fa fa-info-circle"></i> Details
                            </a>
                            <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-gradient-danger">
                                <i class="fa fa-trash"></i> Delete
                            </a>
                        </div>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/js/all.min.js"></script>
}

<!-- Custom CSS for Gradient Buttons -->
<style>
    .btn-gradient-primary {
        background: linear-gradient(45deg, #007bff, #6610f2);
        color: white;
        border: none;
        border-radius: 30px;
        padding: 10px 20px;
        transition: 0.3s;
        box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);
    }

    .btn-gradient-info {
        background: linear-gradient(45deg, #17a2b8, #20c997);
        color: white;
        border: none;
        border-radius: 30px;
        padding: 10px 20px;
        transition: 0.3s;
        box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);
    }

    .btn-gradient-danger {
        background: linear-gradient(45deg, #dc3545, #ff6b6b);
        color: white;
        border: none;
        border-radius: 30px;
        padding: 10px 20px;
        transition: 0.3s;
        box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);
    }

        .btn-gradient-primary:hover, .btn-gradient-info:hover, .btn-gradient-danger:hover {
            transform: translateY(-2px);
            box-shadow: 0px 6px 8px rgba(0, 0, 0, 0.2);
        }
</style>
